# ============================================================================
# User API 测试配置文件 - 中文详细注释版本
# ============================================================================
# 文件说明：
#   这是 User API 服务的测试配置文件
#   位于 test/conf 目录，用于测试环境
#   与开发环境配置基本相同
# ============================================================================

# host: 服务监听地址
host: 0.0.0.0

# jwtauth: JWT 认证配置
jwtauth:
  # accessexpire: JWT token 过期时间（秒）
  # 8640000 秒 = 100 天
  accessexpire: 8640000

  # accesssecret: JWT 签名密钥
  accesssecret: imooc.com

# name: 服务名称
name: user

# port: 服务监听端口
port: 8888

# redisx: Redis 缓存配置
redisx:
  # host: Redis 服务器地址
  host: 192.168.117.24:16379

  # pass: Redis 密码
  pass: easy-chat

# userrpc: User RPC 服务配置
userrpc:
  etcd:
    # hosts: Etcd 服务器地址列表
    hosts:
      - 192.168.117.24:3379

    # key: 服务在 Etcd 中的注册键
    key: user.rpc

# ============================================================================
# 配置说明
# ============================================================================
# 这是测试环境的配置文件
# 与开发环境配置（etc/conf/user-api.yaml）完全相同
#
# 使用场景：
#   1. 单元测试
#   2. 集成测试
#   3. 测试环境部署
#
# 测试建议：
#   - 使用独立的测试数据库
#   - 使用独立的 Redis 实例
#   - 测试数据与生产数据隔离
#
# 启动命令：
#   go run user.go -f test/conf/user-api.yaml
# ============================================================================
