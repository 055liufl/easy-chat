# ============================================================================
# Task MQ 服务配置文件（开发环境）- 中文详细注释版本
# ============================================================================
# 文件说明：
#   这是 Task MQ 服务的开发环境配置文件
#   Task MQ 服务负责消费 Kafka 消息队列中的消息并进行处理
#   是即时通讯系统的消息处理中心
#
# 服务职责：
#   1. 消费聊天消息，存储到 MongoDB
#   2. 消费已读消息，更新消息状态
#   3. 推送消息到在线用户
#   4. 处理离线消息
# ============================================================================

# ----------------------------------------------------------------------------
# 服务基本配置
# ----------------------------------------------------------------------------

# Name: 服务名称
# 作用：标识 Task MQ 服务
Name: task.mq

# ListenOn: 服务监听地址
# 作用：提供健康检查和管理接口
# 注意：这不是 Kafka 消费者的监听地址
ListenOn: 0.0.0.0:10091

# ----------------------------------------------------------------------------
# Kafka 消费者配置 - 聊天消息传输
# ----------------------------------------------------------------------------
# MsgChatTransfer: 聊天消息传输队列消费者配置
# 作用：消费 WebSocket 服务发送的聊天消息
# 处理流程：
#   1. 从 Kafka 消费消息
#   2. 验证消息格式
#   3. 存储消息到 MongoDB
#   4. 推送消息给接收者（如果在线）
#   5. 更新会话信息
MsgChatTransfer:
  # Name: 消费者名称
  # 作用：标识这个消费者
  Name: MsgChatTransfer

  # Brokers: Kafka broker 地址列表
  # 格式：IP:端口
  # 作用：指定 Kafka 集群的地址
  # 配置建议：
  #   - 开发环境：单个 broker 即可
  #   - 生产环境：配置多个 broker 提高可用性
  Brokers:
    - 192.168.117.24:9092

  # Group: 消费者组ID
  # 作用：标识消费者组，同一组内的消费者共同消费消息
  # Kafka 消费者组特性：
  #   - 同一组内的消费者不会重复消费同一条消息
  #   - 不同组的消费者可以独立消费所有消息
  #   - 支持水平扩展（增加消费者提高吞吐量）
  # 命名建议：使用有意义的名称，如 "task-mq-chat"
  Group: kafka

  # Topic: Kafka 主题名称
  # 作用：指定消费哪个主题的消息
  # 必须与生产者（WebSocket 服务）配置的主题一致
  Topic: msgChatTransfer

  # Offset: 消费位置
  # 作用：指定从哪里开始消费消息
  # 可选值：
  #   - first: 从最早的消息开始消费（适合首次启动）
  #   - last: 从最新的消息开始消费（忽略历史消息）
  # 注意：
  #   - 首次启动使用 first 可以消费所有历史消息
  #   - 后续启动会从上次提交的 offset 继续消费
  Offset: first

  # Consumers: 消费者数量
  # 作用：指定启动多少个消费者协程
  # 配置建议：
  #   - 消费者数量 <= 主题分区数
  #   - 根据消息量和处理速度调整
  #   - 开发环境：1 个即可
  #   - 生产环境：根据负载调整（如 4-8 个）
  # 注意：消费者数量超过分区数不会提高性能
  Consumers: 1

# ----------------------------------------------------------------------------
# Kafka 消费者配置 - 消息已读状态传输
# ----------------------------------------------------------------------------
# MsgReadTransfer: 消息已读状态传输队列消费者配置
# 作用：消费 WebSocket 服务发送的消息已读状态
# 处理流程：
#   1. 从 Kafka 消费已读消息
#   2. 更新 MongoDB 中的消息状态
#   3. 推送已读状态给发送者（如果在线）
#   4. 更新会话的未读计数
MsgReadTransfer:
  # Name: 消费者名称
  Name: MsgReadTransfer

  # Brokers: Kafka broker 地址列表
  Brokers:
    - 192.168.117.24:9092

  # Group: 消费者组ID
  # 注意：与聊天消息使用相同的组ID
  Group: kafka

  # Topic: Kafka 主题名称
  # 消费已读状态消息的主题
  Topic: msgReadTransfer

  # Offset: 消费位置
  Offset: first

  # Consumers: 消费者数量
  Consumers: 1

# ----------------------------------------------------------------------------
# 消息已读处理配置
# ----------------------------------------------------------------------------
# MsgReadHandler: 消息已读处理器配置
# 作用：配置群聊消息已读状态的处理策略
# 群聊已读状态处理说明：
#   - 群聊消息的已读状态比较复杂（多人）
#   - 为了提高性能，采用批量处理和延迟更新策略
MsgReadHandler:
  # GroupMsgReadHandler: 群消息已读处理器数量
  # 作用：指定处理群消息已读状态的协程数量
  # 配置建议：根据群聊消息量调整
  GroupMsgReadHandler: 1

  # GroupMsgReadRecordDelayTime: 群消息已读记录延迟时间
  # 单位：秒
  # 作用：延迟多久后批量更新已读状态
  # 原因：
  #   - 群聊中多人同时阅读消息
  #   - 延迟批量更新可以减少数据库写入次数
  #   - 提高系统性能
  # 配置建议：2-5 秒
  GroupMsgReadRecordDelayTime: 2

  # GroupMsgReadRecordDelayCount: 群消息已读记录延迟数量
  # 作用：累积多少条已读记录后触发批量更新
  # 原因：
  #   - 避免等待时间过长
  #   - 达到数量阈值立即更新
  # 配置建议：根据群规模调整（如 2-10）
  GroupMsgReadRecordDelayCount: 2

# ----------------------------------------------------------------------------
# Redis 缓存配置
# ----------------------------------------------------------------------------
# Redisx: Redis 缓存配置
# 作用：缓存在线用户信息、会话信息等
# 使用场景：
#   - 查询用户是否在线
#   - 缓存会话信息
#   - 缓存未读消息计数
Redisx:
  # Host: Redis 服务器地址
  Host: 192.168.117.24:16379

  # Type: Redis 类型
  # 可选值：node（单节点）、cluster（集群）
  Type: node

  # Pass: Redis 密码
  Pass: easy-chat

# ----------------------------------------------------------------------------
# MongoDB 数据库配置
# ----------------------------------------------------------------------------
# Mongo: MongoDB 数据库连接配置
# 作用：存储聊天消息和会话信息
Mongo:
  # Url: MongoDB 连接字符串
  Url: "mongodb://root:easy-chat@192.168.117.24:47017"

  # Db: 数据库名称
  Db: easy-chat

# ----------------------------------------------------------------------------
# RPC 服务依赖配置
# ----------------------------------------------------------------------------
# SocialRpc: Social RPC 服务配置
# 作用：查询社交关系（如群成员列表）
# 使用场景：
#   - 群聊消息需要查询群成员列表
#   - 验证用户是否有权限发送消息
SocialRpc:
  Etcd:
    Hosts:
      - 192.168.117.24:3379
    Key: social.rpc

# ----------------------------------------------------------------------------
# WebSocket 服务配置
# ----------------------------------------------------------------------------
# Ws: WebSocket 服务地址配置
# 作用：推送消息到 WebSocket 服务
# 工作流程：
#   1. Task MQ 处理完消息后
#   2. 通过 HTTP 请求通知 WebSocket 服务
#   3. WebSocket 服务推送消息给在线用户
Ws:
  # Host: WebSocket 服务地址
  # 格式：IP:端口
  # 注意：这是 WebSocket 服务的内部通信地址
  Host: 192.168.117.24:10090

# ============================================================================
# Task MQ 服务架构说明
# ============================================================================
# Task MQ 服务在系统中的角色：
#
# 消息流转架构：
#
#   WebSocket 服务          Kafka              Task MQ 服务
#        |                    |                      |
#        |--1. 生产消息------>|                      |
#        |                    |--2. 消费消息-------->|
#        |                    |                      |--3. 存储 MongoDB
#        |                    |                      |--4. 查询 Social RPC
#        |                    |                      |--5. 查询 Redis（在线状态）
#        |<-6. 推送请求-------|                      |
#        |                    |                      |
#   在线用户                  |                      |
#        |<-7. 推送消息-------|                      |
#
# ============================================================================
# 消息处理流程详解
# ============================================================================
# 1. 聊天消息处理流程：
#
#    a. 消费消息：
#       - 从 Kafka 的 msgChatTransfer 主题消费消息
#       - 解析消息内容
#
#    b. 验证消息：
#       - 验证消息格式
#       - 验证发送者和接收者
#       - 验证权限（如是否为好友、是否为群成员）
#
#    c. 存储消息：
#       - 将消息存储到 MongoDB 的 messages 集合
#       - 生成消息ID和时间戳
#
#    d. 更新会话：
#       - 更新会话的最后消息
#       - 更新会话的最后消息时间
#       - 增加接收者的未读计数
#
#    e. 推送消息：
#       - 查询接收者是否在线（Redis）
#       - 如果在线，通过 WebSocket 服务推送消息
#       - 如果离线，标记为离线消息
#
# 2. 已读消息处理流程：
#
#    a. 消费消息：
#       - 从 Kafka 的 msgReadTransfer 主题消费消息
#       - 解析已读消息ID列表
#
#    b. 批量处理（群聊）：
#       - 累积已读记录
#       - 达到时间或数量阈值后批量更新
#
#    c. 更新状态：
#       - 更新 MongoDB 中的消息状态
#       - 更新会话的未读计数
#
#    d. 推送状态：
#       - 查询发送者是否在线
#       - 如果在线，推送已读状态
#
# ============================================================================
# Kafka 消费者组说明
# ============================================================================
# 消费者组的作用：
#
# 1. 负载均衡：
#    - 同一组内的多个消费者共同消费消息
#    - Kafka 自动分配分区给消费者
#    - 每个分区只会被组内一个消费者消费
#
# 2. 水平扩展：
#    - 增加消费者数量可以提高吞吐量
#    - 最多可以有 N 个消费者（N = 分区数）
#
# 3. 故障转移：
#    - 消费者故障时，Kafka 自动重新分配分区
#    - 保证消息不丢失
#
# 示例：
#   主题有 8 个分区，消费者组有 4 个消费者
#   - 消费者1: 分区 0, 1
#   - 消费者2: 分区 2, 3
#   - 消费者3: 分区 4, 5
#   - 消费者4: 分区 6, 7
#
# ============================================================================
# 性能优化建议
# ============================================================================
# 1. Kafka 消费优化：
#    - 增加主题分区数提高并行度
#    - 增加消费者数量（不超过分区数）
#    - 批量消费消息减少网络开销
#    - 异步提交 offset 提高性能
#
# 2. 数据库优化：
#    - 批量写入 MongoDB
#    - 使用索引优化查询
#    - 使用连接池
#    - 考虑分片（数据量大时）
#
# 3. 消息推送优化：
#    - 批量推送消息
#    - 使用异步推送
#    - 失败重试机制
#    - 推送超时控制
#
# 4. 内存优化：
#    - 及时释放消息对象
#    - 使用对象池
#    - 控制消费速率
#    - 监控内存使用
#
# ============================================================================
# 高可用和容错
# ============================================================================
# 1. 消息不丢失：
#    - Kafka 持久化消息
#    - 消费成功后才提交 offset
#    - 失败消息重试
#    - 死信队列处理失败消息
#
# 2. 服务高可用：
#    - 部署多个 Task MQ 实例
#    - 使用消费者组实现负载均衡
#    - 自动故障转移
#
# 3. 数据一致性：
#    - 幂等性处理（防止重复消费）
#    - 事务保证数据一致性
#    - 补偿机制处理异常
#
# ============================================================================
# 监控和告警
# ============================================================================
# 1. 关键指标：
#    - 消息消费速率
#    - 消息处理延迟
#    - 消费者 lag（积压消息数）
#    - 错误率
#    - 数据库写入性能
#
# 2. 告警设置：
#    - 消费者 lag 过大（消息积压）
#    - 消息处理失败率过高
#    - 数据库连接异常
#    - 服务不可用
#
# 3. 日志记录：
#    - 记录消息消费情况
#    - 记录处理错误
#    - 记录性能指标
#
# ============================================================================
# 开发环境使用指南
# ============================================================================
# 1. 启动前准备：
#    # 确保依赖服务运行
#    - Kafka: 192.168.117.24:9092
#    - MongoDB: 192.168.117.24:47017
#    - Redis: 192.168.117.24:16379
#    - Social RPC: 已启动
#    - WebSocket 服务: 192.168.117.24:10090
#
#    # 创建 Kafka 主题
#    kafka-topics.sh --create --topic msgChatTransfer \
#      --bootstrap-server 192.168.117.24:9092 \
#      --partitions 8 --replication-factor 1
#
#    kafka-topics.sh --create --topic msgReadTransfer \
#      --bootstrap-server 192.168.117.24:9092 \
#      --partitions 8 --replication-factor 1
#
# 2. 启动服务：
#    cd /home/lfl/easy-chat1/apps/task/mq
#    go run task.go -f etc/dev/task.yaml
#
# 3. 监控消费情况：
#    # 查看消费者组状态
#    kafka-consumer-groups.sh --describe --group kafka \
#      --bootstrap-server 192.168.117.24:9092
#
#    # 查看主题消息数量
#    kafka-run-class.sh kafka.tools.GetOffsetShell \
#      --broker-list 192.168.117.24:9092 \
#      --topic msgChatTransfer
#
# 4. 测试消息处理：
#    # 发送测试消息到 Kafka
#    kafka-console-producer.sh --topic msgChatTransfer \
#      --bootstrap-server 192.168.117.24:9092
#
#    # 查看 MongoDB 中的消息
#    mongo mongodb://root:easy-chat@192.168.117.24:47017/easy-chat
#    db.messages.find().limit(10)
# ============================================================================
