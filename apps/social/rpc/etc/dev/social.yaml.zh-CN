# ============================================================================
# Social RPC 服务配置文件（开发环境）- 中文详细注释版本
# ============================================================================
# 文件说明：
#   这是 Social RPC 服务的开发环境配置文件
#   使用 Go-Zero 推荐的大写驼峰命名风格
# ============================================================================

# Name: 服务名称
Name: social.rpc

# ListenOn: RPC 服务监听地址
# 格式：IP:端口
ListenOn: 0.0.0.0:10001

# ----------------------------------------------------------------------------
# 服务注册与发现配置
# ----------------------------------------------------------------------------
Etcd:
  Hosts:
    - 192.168.117.24:3379
  Key: social.rpc

# ----------------------------------------------------------------------------
# MySQL 数据库配置
# ----------------------------------------------------------------------------
Mysql:
  # DataSource: MySQL 连接字符串
  # 格式：用户名:密码@tcp(主机:端口)/数据库名?参数
  # 参数说明：
  #   - charset=utf8mb4: 字符集，支持 emoji 等特殊字符
  #   - parseTime=true: 自动解析 time.Time 类型
  DataSource: root:easy-chat@tcp(192.168.117.24:13306)/easy-chat?charset=utf8mb4&parseTime=true

# ----------------------------------------------------------------------------
# Redis 缓存配置
# ----------------------------------------------------------------------------
# Cache: Go-Zero 缓存配置
# 作用：配置 Redis 缓存，提高查询性能
# Go-Zero 会自动使用缓存优化数据库查询
Cache:
  - Host: 192.168.117.24:16379  # Redis 服务器地址
    Type: node                   # 缓存类型：node（单节点模式）
    Pass: easy-chat              # Redis 密码

# ============================================================================
# 配置说明
# ============================================================================
# 本配置文件是开发环境的完整配置
# 包含了 Social RPC 服务运行所需的所有配置项
#
# 与 conf/social-rpc.yaml 的区别：
#   1. 使用大写驼峰命名（推荐）
#   2. 配置项更清晰
#   3. 没有 timeout 配置（使用默认值）
#
# 启动命令：
#   go run social.go -f etc/dev/social.yaml
# ============================================================================
