# ============================================================================
# Social API 服务配置文件（开发环境）- 中文详细注释版本
# ============================================================================
# 文件说明：
#   这是 Social API 服务的开发环境配置文件
#   使用 Go-Zero 推荐的大写驼峰命名风格
#   包含完整的服务配置和依赖配置
# ============================================================================

# ----------------------------------------------------------------------------
# 服务基本配置
# ----------------------------------------------------------------------------

# Name: 服务名称
Name: social

# Host: 服务监听地址
Host: 0.0.0.0

# Port: 服务监听端口
Port: 8881

# ----------------------------------------------------------------------------
# Redis 缓存配置
# ----------------------------------------------------------------------------
# Redisx: Redis 缓存配置（Go-Zero 自定义配置名称）
# 作用：缓存社交关系数据，提高查询性能
Redisx:
  # Host: Redis 服务器地址
  # 格式：IP:端口
  Host: 192.168.117.24:16379

  # Pass: Redis 密码
  Pass: easy-chat

# ----------------------------------------------------------------------------
# RPC 服务依赖配置
# ----------------------------------------------------------------------------

# SocialRpc: Social RPC 服务配置
# 作用：Social API 调用 Social RPC 处理业务逻辑
SocialRpc:
  Etcd:
    Hosts:
      - 192.168.117.24:3379
    Key: social.rpc

# UserRpc: User RPC 服务配置
# 作用：获取用户信息，验证用户
UserRpc:
  Etcd:
    Hosts:
      - 192.168.117.24:3379
    Key: user.rpc

# ImRpc: IM RPC 服务配置
# 作用：创建会话，发送系统消息
ImRpc:
  Etcd:
    Hosts:
      - 192.168.117.24:3379
    Key: im.rpc

# ----------------------------------------------------------------------------
# JWT 认证配置
# ----------------------------------------------------------------------------
# JwtAuth: JWT 认证配置
JwtAuth:
  # AccessSecret: JWT 签名密钥
  # 必须与其他服务保持一致
  AccessSecret: imooc.com

# ============================================================================
# 开发环境配置说明
# ============================================================================
# 本配置文件适用于开发和测试环境
# 相比生产环境的主要区别：
#   1. 使用开发环境的数据库和缓存
#   2. 超时时间可以设置较长便于调试
#   3. 日志级别可以设置为 debug
#   4. 可以使用简单的密钥
#
# 启动命令：
#   go run social.go -f etc/dev/social.yaml
# ============================================================================
