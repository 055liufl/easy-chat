# ============================================================================
# IM WebSocket 服务配置文件（开发环境）- 中文详细注释版本
# ============================================================================
# 文件说明：
#   这是 easy-chat 即时通讯系统中 IM WebSocket 服务的开发环境配置文件
#   WebSocket 服务负责维持与客户端的长连接，实现实时消息推送
#   是即时通讯系统的核心组件之一
#
# WebSocket 服务说明：
#   WebSocket 是一种全双工通信协议，适合实时通讯场景
#   优势：
#     - 实时双向通信
#     - 低延迟
#     - 减少网络开销
#     - 服务器可主动推送消息
# ============================================================================

# ----------------------------------------------------------------------------
# 服务基本配置
# ----------------------------------------------------------------------------

# Name: 服务名称
# 作用：标识 WebSocket 服务
# 命名规范：服务名.ws
# 用途：
#   - 日志记录中的服务标识
#   - 监控系统中的服务名称
#   - 区分不同的服务实例
Name: im.ws

# ListenOn: WebSocket 服务监听地址
# 作用：指定 WebSocket 服务监听的地址和端口
# 格式：IP:端口
# 配置说明：
#   - 0.0.0.0: 监听所有网络接口（推荐）
#   - 端口 10090: WebSocket 服务专用端口
# 客户端连接示例：
#   ws://192.168.117.24:10090/ws
#   wss://192.168.117.24:10090/ws (使用 SSL/TLS)
# 注意：
#   - 生产环境建议使用 wss:// 加密连接
#   - 需要配置负载均衡器支持 WebSocket 协议
ListenOn: 0.0.0.0:10090

# ----------------------------------------------------------------------------
# JWT 认证配置
# ----------------------------------------------------------------------------
# JwtAuth: JWT 认证配置
# 作用：验证 WebSocket 连接的客户端身份
# WebSocket 认证流程：
#   1. 客户端先通过 API 登录获取 JWT token
#   2. 建立 WebSocket 连接时携带 token
#   3. 服务端验证 token 的有效性
#   4. 验证通过后建立长连接
JwtAuth:
  # AccessSecret: JWT 签名密钥
  # 作用：验证客户端提供的 JWT token
  # 重要：必须与 API 服务使用相同的密钥
  # 安全建议：
  #   - 生产环境使用强密码
  #   - 定期轮换密钥
  #   - 使用环境变量或密钥管理服务
  AccessSecret: imooc.com

# ----------------------------------------------------------------------------
# MongoDB 数据库配置
# ----------------------------------------------------------------------------
# Mongo: MongoDB 数据库连接配置
# 作用：WebSocket 服务使用 MongoDB 存储和查询消息
# 使用场景：
#   - 查询历史消息
#   - 存储离线消息
#   - 更新消息状态（已读/未读）
Mongo:
  # Url: MongoDB 连接字符串
  # 格式：mongodb://用户名:密码@主机:端口
  # 连接说明：
  #   - root: 数据库管理员用户
  #   - easy-chat: 数据库密码
  #   - 192.168.117.24:47017: MongoDB 服务器地址
  # 连接池配置建议：
  #   - WebSocket 服务通常有大量并发连接
  #   - 建议配置较大的连接池：?maxPoolSize=200
  Url: "mongodb://root:easy-chat@192.168.117.24:47017"

  # Db: 数据库名称
  # 作用：指定使用的数据库
  # 与 IM RPC 服务使用相同的数据库
  Db: easy-chat

# ----------------------------------------------------------------------------
# Kafka 消息队列配置 - 聊天消息传输
# ----------------------------------------------------------------------------
# MsgChatTransfer: 聊天消息传输队列配置
# 作用：将接收到的聊天消息发送到 Kafka 队列进行异步处理
# 消息流转过程：
#   1. 客户端通过 WebSocket 发送消息
#   2. WebSocket 服务接收消息
#   3. 将消息发送到 Kafka 的 msgChatTransfer 主题
#   4. Task MQ 服务消费消息并处理（存储、推送等）
# 为什么使用 Kafka：
#   - 解耦消息接收和处理
#   - 提高系统吞吐量
#   - 保证消息不丢失
#   - 支持消息重试
MsgChatTransfer:
  # Topic: Kafka 主题名称
  # 作用：指定消息发送到哪个主题
  # 命名规范：使用驼峰命名法
  # 主题说明：
  #   msgChatTransfer 主题专门用于传输聊天消息
  Topic: msgChatTransfer

  # Addrs: Kafka 服务器地址列表
  # 格式：IP:端口
  # 配置说明：
  #   - 支持配置多个 Kafka broker 地址
  #   - 提高可用性和容错能力
  # 生产环境建议：
  #   - 配置至少 3 个 broker 地址
  #   - 使用负载均衡
  Addrs:
    - 192.168.117.24:9092

# ----------------------------------------------------------------------------
# Kafka 消息队列配置 - 消息已读状态传输
# ----------------------------------------------------------------------------
# MsgReadTransfer: 消息已读状态传输队列配置
# 作用：将消息已读状态变更发送到 Kafka 队列
# 使用场景：
#   1. 用户阅读消息后，客户端发送已读回执
#   2. WebSocket 服务接收已读回执
#   3. 将已读状态发送到 Kafka 的 msgReadTransfer 主题
#   4. Task MQ 服务消费并更新数据库中的消息状态
# 为什么单独处理已读状态：
#   - 已读状态更新频繁，单独队列避免影响消息发送
#   - 可以批量处理已读状态，提高性能
#   - 已读状态丢失影响较小，可以降低处理优先级
MsgReadTransfer:
  # Topic: Kafka 主题名称
  # 作用：指定已读状态消息发送到哪个主题
  # 主题说明：
  #   msgReadTransfer 主题专门用于传输消息已读状态
  Topic: msgReadTransfer

  # Addrs: Kafka 服务器地址列表
  # 与 MsgChatTransfer 使用相同的 Kafka 集群
  Addrs:
    - 192.168.117.24:9092

# ============================================================================
# WebSocket 服务架构说明
# ============================================================================
# WebSocket 服务在系统中的角色：
#
# 1. 连接管理：
#    - 维护与客户端的 WebSocket 长连接
#    - 管理在线用户列表
#    - 处理连接建立、断开、心跳
#
# 2. 消息接收：
#    - 接收客户端发送的消息
#    - 验证消息格式和权限
#    - 将消息发送到 Kafka 队列
#
# 3. 消息推送：
#    - 接收来自 Task MQ 的推送请求
#    - 将消息推送给在线用户
#    - 处理离线消息
#
# 4. 状态同步：
#    - 同步消息已读状态
#    - 同步用户在线状态
#    - 同步会话信息
#
# ============================================================================
# 消息流转架构
# ============================================================================
# 发送消息流程：
#
#   客户端 A                WebSocket 服务           Kafka              Task MQ 服务
#      |                         |                     |                      |
#      |--1. 发送消息----------->|                     |                      |
#      |                         |--2. 生产消息------->|                      |
#      |                         |                     |--3. 消费消息-------->|
#      |                         |                     |                      |--4. 存储到 MongoDB
#      |                         |                     |                      |--5. 推送请求
#      |                         |<-6. 推送消息--------|                      |
#      |                         |                     |                      |
#   客户端 B                     |                     |                      |
#      |<-7. 接收消息------------|                     |                      |
#
# 已读状态流程：
#
#   客户端 B                WebSocket 服务           Kafka              Task MQ 服务
#      |                         |                     |                      |
#      |--1. 发送已读回执------->|                     |                      |
#      |                         |--2. 生产消息------->|                      |
#      |                         |                     |--3. 消费消息-------->|
#      |                         |                     |                      |--4. 更新 MongoDB
#      |                         |                     |                      |--5. 推送已读状态
#      |                         |<-6. 推送状态--------|                      |
#   客户端 A                     |                     |                      |
#      |<-7. 接收已读状态--------|                     |                      |
#
# ============================================================================
# WebSocket 连接管理
# ============================================================================
# 1. 连接建立：
#    - 客户端发起 WebSocket 连接请求
#    - 携带 JWT token 进行身份验证
#    - 验证通过后建立连接
#    - 将连接信息存储到内存（用户ID -> 连接对象）
#
# 2. 心跳机制：
#    - 客户端定期发送 ping 消息（如每 30 秒）
#    - 服务端响应 pong 消息
#    - 超时未收到心跳则断开连接
#    - 防止僵尸连接占用资源
#
# 3. 连接断开：
#    - 客户端主动断开
#    - 网络异常断开
#    - 服务端主动断开（如用户被踢出）
#    - 清理连接信息和相关资源
#
# 4. 重连机制：
#    - 客户端检测到断开后自动重连
#    - 使用指数退避策略（1s, 2s, 4s, 8s...）
#    - 重连成功后同步离线消息
#
# ============================================================================
# 消息格式定义
# ============================================================================
# WebSocket 消息格式（JSON）：
#
# 1. 客户端发送消息：
#    {
#      "type": "chat",           // 消息类型：chat, read, heartbeat
#      "data": {
#        "to": "user_002",       // 接收者ID
#        "content": "Hello",     // 消息内容
#        "msg_type": 1,          // 消息类型：1文本 2图片 3语音 4视频
#        "conversation_id": "conv_123"  // 会话ID
#      },
#      "timestamp": 1704096000000  // 时间戳
#    }
#
# 2. 服务端推送消息：
#    {
#      "type": "message",        // 消息类型：message, read, system
#      "data": {
#        "id": "msg_001",        // 消息ID
#        "from": "user_001",     // 发送者ID
#        "content": "Hello",     // 消息内容
#        "msg_type": 1,          // 消息类型
#        "send_time": 1704096000000  // 发送时间
#      }
#    }
#
# 3. 心跳消息：
#    客户端：{"type": "ping"}
#    服务端：{"type": "pong"}
#
# 4. 已读回执：
#    {
#      "type": "read",
#      "data": {
#        "message_ids": ["msg_001", "msg_002"],  // 已读消息ID列表
#        "conversation_id": "conv_123"           // 会话ID
#      }
#    }
#
# ============================================================================
# 开发环境使用指南
# ============================================================================
# 1. 启动前准备：
#    # 确保依赖服务运行
#    - MongoDB: 192.168.117.24:47017
#    - Kafka: 192.168.117.24:9092
#    - Zookeeper: 192.168.117.24:2181
#
#    # 验证服务状态
#    mongo mongodb://root:easy-chat@192.168.117.24:47017
#    kafka-topics.sh --list --bootstrap-server 192.168.117.24:9092
#
# 2. 启动服务：
#    cd /home/lfl/easy-chat1/apps/im/ws
#    go run ws.go -f etc/dev/im.yaml
#
# 3. 测试 WebSocket 连接：
#    # 使用 wscat 工具测试（需要安装 wscat）
#    wscat -c ws://192.168.117.24:10090/ws -H "Authorization: Bearer <TOKEN>"
#
#    # 或使用浏览器 JavaScript
#    const ws = new WebSocket('ws://192.168.117.24:10090/ws');
#    ws.onopen = () => {
#      ws.send(JSON.stringify({type: 'ping'}));
#    };
#    ws.onmessage = (event) => {
#      console.log('Received:', event.data);
#    };
#
# 4. 监控连接状态：
#    - 查看日志输出
#    - 监控在线用户数
#    - 监控消息发送量
#
# ============================================================================
# 性能优化建议
# ============================================================================
# 1. 连接管理优化：
#    - 使用高效的数据结构存储连接（如 sync.Map）
#    - 定期清理无效连接
#    - 限制单个服务器的最大连接数
#    - 使用连接池管理数据库连接
#
# 2. 消息处理优化：
#    - 使用消息队列异步处理
#    - 批量发送消息到 Kafka
#    - 使用 goroutine 池控制并发
#    - 避免阻塞操作
#
# 3. 内存优化：
#    - 及时释放断开连接的资源
#    - 使用对象池减少 GC 压力
#    - 限制消息大小
#    - 监控内存使用情况
#
# 4. 网络优化：
#    - 启用消息压缩
#    - 合并小消息减少网络开销
#    - 使用二进制协议（如 Protocol Buffers）
#    - 配置合适的缓冲区大小
#
# ============================================================================
# 高可用和扩展性
# ============================================================================
# 1. 水平扩展：
#    - 部署多个 WebSocket 服务实例
#    - 使用负载均衡器分发连接
#    - 通过 Redis 共享在线用户信息
#    - 使用 Kafka 实现跨实例消息推送
#
# 2. 负载均衡：
#    - 使用支持 WebSocket 的负载均衡器（如 Nginx）
#    - 配置会话保持（Sticky Session）
#    - 或使用一致性哈希分配连接
#
# 3. 故障转移：
#    - 客户端实现自动重连
#    - 服务端保存离线消息
#    - 使用健康检查自动摘除故障节点
#
# ============================================================================
# 监控和告警
# ============================================================================
# 1. 关键指标：
#    - 在线连接数
#    - 消息发送/接收速率
#    - 消息延迟
#    - 连接建立/断开速率
#    - 错误率
#
# 2. 日志记录：
#    - 连接建立和断开
#    - 消息发送和接收
#    - 错误和异常
#    - 性能指标
#
# 3. 告警设置：
#    - 连接数异常告警
#    - 消息延迟过高告警
#    - 错误率过高告警
#    - 服务不可用告警
# ============================================================================
