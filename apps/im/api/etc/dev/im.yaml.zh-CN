# ============================================================================
# IM API 服务配置文件（开发环境）- 中文详细注释版本
# ============================================================================
# 文件说明：
#   这是 easy-chat 即时通讯系统中 IM API 服务的开发环境配置文件
#   相比 conf 目录下的配置，这个文件使用了 Go-Zero 推荐的大写命名风格
#   适用于开发和测试环境
#
# 配置风格说明：
#   Go-Zero 支持两种配置风格：
#   1. 小写风格：name, host, port（旧版本）
#   2. 大写驼峰风格：Name, Host, Port（推荐，新版本）
#   本文件采用大写驼峰风格
# ============================================================================

# ----------------------------------------------------------------------------
# 服务基本配置
# ----------------------------------------------------------------------------

# Name: 服务名称
# 作用：标识当前服务，用于服务注册、日志记录、链路追踪等
# 命名规范：
#   - 使用小写字母
#   - 多个单词用点号分隔（如：im.api）
#   - 保持简洁明了
# 使用场景：
#   - 在 Etcd 中注册服务时作为服务标识
#   - 在日志中标识日志来源
#   - 在监控系统中区分不同服务
Name: im

# Host: 服务监听的主机地址
# 作用：指定服务绑定的网络接口
# 可选值：
#   - 0.0.0.0: 监听所有网络接口（容器环境推荐）
#   - 127.0.0.1: 仅本地访问（本地开发推荐）
#   - 具体IP: 监听指定网络接口
# 开发环境建议：使用 0.0.0.0 方便团队成员访问
Host: 0.0.0.0

# Port: 服务监听的端口号
# 作用：HTTP API 服务的监听端口
# 端口规划：
#   - 8888: user API 服务
#   - 8881: social API 服务
#   - 8882: im API 服务
# 注意：确保端口不冲突
Port: 8882

# ----------------------------------------------------------------------------
# RPC 服务依赖配置 - IM RPC 服务
# ----------------------------------------------------------------------------
# ImRpc: IM RPC 服务客户端配置
# 作用：配置如何连接到 IM RPC 服务
# IM RPC 提供的功能：
#   - 消息存储和查询
#   - 会话管理
#   - 消息推送
ImRpc:
  # Etcd: 服务发现配置
  # Go-Zero 使用 Etcd 实现服务注册与发现
  # 优势：
  #   - 自动服务发现
  #   - 负载均衡
  #   - 故障转移
  Etcd:
    # Hosts: Etcd 服务器地址列表
    # 格式：IP:端口
    # 支持配置多个地址：
    #   - 提高可用性
    #   - 自动故障转移
    # 开发环境：通常配置单个地址即可
    # 生产环境：建议配置 3 个或 5 个节点（奇数个）
    Hosts:
      - 192.168.117.24:3379

    # Key: 服务在 Etcd 中的注册键
    # 作用：用于查找 IM RPC 服务的所有实例
    # 命名规范：服务名.rpc
    # 工作原理：
    #   1. IM RPC 服务启动时将自己的地址注册到 Etcd 的这个 key 下
    #   2. API 服务通过这个 key 查询所有可用的 RPC 服务实例
    #   3. Go-Zero 自动实现负载均衡和故障转移
    Key: im.rpc

# ----------------------------------------------------------------------------
# RPC 服务依赖配置 - User RPC 服务
# ----------------------------------------------------------------------------
# UserRpc: 用户 RPC 服务客户端配置
# 作用：配置如何连接到用户 RPC 服务
# User RPC 提供的功能：
#   - 用户信息查询
#   - 用户认证
#   - 用户状态管理
UserRpc:
  Etcd:
    Hosts:
      - 192.168.117.24:3379
    Key: user.rpc

# ----------------------------------------------------------------------------
# RPC 服务依赖配置 - Social RPC 服务
# ----------------------------------------------------------------------------
# SocialRpc: 社交 RPC 服务客户端配置
# 作用：配置如何连接到社交 RPC 服务
# Social RPC 提供的功能：
#   - 好友关系管理
#   - 群组管理
#   - 社交关系查询
SocialRpc:
  Etcd:
    Hosts:
      - 192.168.117.24:3379
    Key: social.rpc

# ----------------------------------------------------------------------------
# JWT 认证配置
# ----------------------------------------------------------------------------
# JwtAuth: JWT 认证配置
# 作用：配置 JWT token 的生成和验证
# JWT 工作流程：
#   1. 用户登录成功后，服务端生成 JWT token
#   2. 客户端在后续请求中携带 token（通常在 Authorization header）
#   3. 服务端验证 token 的有效性
#   4. 验证通过后处理业务请求
JwtAuth:
  # AccessSecret: JWT 签名密钥
  # 作用：用于生成和验证 JWT token 的签名
  # 安全要求：
  #   - 开发环境：可以使用简单密钥方便调试
  #   - 生产环境：必须使用强密码（建议 32 位以上随机字符串）
  # 重要提示：
  #   - 所有需要验证 JWT 的服务必须使用相同的密钥
  #   - 密钥泄露会导致严重的安全问题
  #   - 定期轮换密钥（建议每 3-6 个月）
  # 最佳实践：
  #   - 使用环境变量存储密钥
  #   - 不要将密钥提交到版本控制系统
  #   - 使用密钥管理服务（如 AWS KMS、HashiCorp Vault）
  AccessSecret: imooc.com

# ============================================================================
# 服务架构说明
# ============================================================================
# IM API 服务在系统中的角色：
#
# 1. 作为 HTTP API 网关：
#    - 接收客户端的 HTTP 请求
#    - 验证用户身份（JWT）
#    - 将请求转发给相应的 RPC 服务
#    - 返回处理结果给客户端
#
# 2. 服务依赖关系：
#    IM API 服务
#    ├── IM RPC 服务（消息相关功能）
#    ├── User RPC 服务（用户信息）
#    └── Social RPC 服务（社交关系）
#
# 3. 通信方式：
#    - 客户端 <--HTTP--> IM API 服务
#    - IM API <--gRPC--> RPC 服务
#
# ============================================================================
# 请求处理流程示例
# ============================================================================
# 以发送消息为例：
#
# 1. 客户端发送 HTTP POST 请求到 IM API
#    POST http://192.168.117.24:8882/api/message/send
#    Headers: Authorization: Bearer <JWT_TOKEN>
#    Body: {"to": "user123", "content": "Hello"}
#
# 2. IM API 服务处理：
#    a. 验证 JWT token（使用 AccessSecret）
#    b. 解析请求参数
#    c. 调用 User RPC 验证接收者是否存在
#    d. 调用 Social RPC 检查是否为好友关系
#    e. 调用 IM RPC 存储消息
#    f. 返回结果给客户端
#
# 3. RPC 调用过程：
#    a. 从 Etcd 获取 RPC 服务地址
#    b. 选择一个可用实例（负载均衡）
#    c. 发起 gRPC 调用
#    d. 处理响应或错误
#
# ============================================================================
# 开发环境使用指南
# ============================================================================
# 1. 启动前准备：
#    - 确保 Etcd 服务运行在 192.168.117.24:3379
#    - 确保 IM RPC、User RPC、Social RPC 服务已启动并注册到 Etcd
#    - 确保端口 8882 未被占用
#
# 2. 启动服务：
#    cd /home/lfl/easy-chat1/apps/im/api
#    go run im.go -f etc/dev/im.yaml
#
# 3. 验证服务：
#    # 健康检查
#    curl http://localhost:8882/health
#
#    # 测试 API（需要有效的 JWT token）
#    curl -H "Authorization: Bearer <TOKEN>" \
#         http://localhost:8882/api/message/list
#
# 4. 调试技巧：
#    - 查看日志输出定位问题
#    - 使用 Postman 或 curl 测试 API
#    - 检查 Etcd 中的服务注册信息
#    - 使用 Go-Zero 的内置监控端点
#
# ============================================================================
# 常见问题和解决方案
# ============================================================================
# 1. 服务启动失败：
#    问题：端口被占用
#    解决：lsof -i:8882 查看占用进程，kill 或修改端口
#
# 2. 无法连接 RPC 服务：
#    问题：Etcd 连接失败或 RPC 服务未注册
#    解决：
#      - 检查 Etcd 是否运行：curl http://192.168.117.24:3379/health
#      - 检查 RPC 服务是否注册：etcdctl get --prefix /
#
# 3. JWT 验证失败：
#    问题：AccessSecret 不一致
#    解决：确保所有服务使用相同的 AccessSecret
#
# 4. RPC 调用超时：
#    问题：网络延迟或 RPC 服务响应慢
#    解决：
#      - 检查网络连接
#      - 增加超时时间配置
#      - 优化 RPC 服务性能
#
# ============================================================================
# 配置优化建议
# ============================================================================
# 1. 开发环境优化：
#    - 使用本地 Etcd 减少网络延迟
#    - 启用详细日志便于调试
#    - 使用热重载工具提高开发效率
#
# 2. 性能优化：
#    - 配置 RPC 连接池
#    - 启用 gRPC 连接复用
#    - 合理设置超时时间
#
# 3. 安全加固：
#    - 生产环境修改默认密钥
#    - 启用 HTTPS
#    - 配置访问控制
#    - 启用请求限流
#
# 4. 监控和日志：
#    - 集成 Prometheus 监控
#    - 配置日志收集（如 ELK）
#    - 启用链路追踪（如 Jaeger）
# ============================================================================
