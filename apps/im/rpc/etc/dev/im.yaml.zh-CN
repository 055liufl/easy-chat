# ============================================================================
# IM RPC 服务配置文件（开发环境）- 中文详细注释版本
# ============================================================================
# 文件说明：
#   这是 easy-chat 即时通讯系统中 IM RPC 服务的开发环境配置文件
#   IM RPC 服务提供即时通讯的核心功能，包括消息存储、查询等
#   使用 gRPC 协议提供服务，供 API 服务调用
#
# RPC 服务说明：
#   RPC (Remote Procedure Call) 远程过程调用
#   Go-Zero 使用 gRPC 作为 RPC 通信协议
#   优势：高性能、类型安全、支持多语言
# ============================================================================

# ----------------------------------------------------------------------------
# 服务基本配置
# ----------------------------------------------------------------------------

# Name: 服务名称
# 作用：标识当前 RPC 服务
# 命名规范：服务名.rpc
# 用途：
#   - 服务注册到 Etcd 时的标识
#   - 日志记录中的服务标识
#   - 监控系统中的服务名称
Name: im.rpc

# ListenOn: RPC 服务监听地址
# 作用：指定 gRPC 服务监听的地址和端口
# 格式：IP:端口
# 配置说明：
#   - 0.0.0.0: 监听所有网络接口（推荐）
#   - 127.0.0.1: 仅本地访问
#   - 具体IP: 监听指定网络接口
# 端口规划：
#   - 10000: user RPC 服务
#   - 10001: social RPC 服务
#   - 10002: im RPC 服务
# 注意：
#   - 确保端口未被占用
#   - 防火墙需要开放此端口（如果跨主机访问）
ListenOn: 0.0.0.0:10002

# ----------------------------------------------------------------------------
# 服务注册与发现配置
# ----------------------------------------------------------------------------
# Etcd: 服务注册与发现配置
# 作用：将 RPC 服务注册到 Etcd，供其他服务发现和调用
# Go-Zero 的服务发现机制：
#   1. RPC 服务启动时自动注册到 Etcd
#   2. 定期发送心跳保持注册状态
#   3. 服务停止时自动注销
#   4. 客户端通过 Etcd 发现可用的服务实例
Etcd:
  # Hosts: Etcd 服务器地址列表
  # 作用：指定 Etcd 集群的地址
  # 格式：IP:端口
  # 配置建议：
  #   - 开发环境：单个地址即可
  #   - 生产环境：配置多个地址（3 或 5 个节点）
  # 高可用说明：
  #   - 配置多个地址后，如果一个节点故障，会自动切换到其他节点
  #   - Etcd 集群建议使用奇数个节点（3、5、7）
  Hosts:
    - 192.168.117.24:3379

  # Key: 服务在 Etcd 中的注册键
  # 作用：服务注册的唯一标识
  # 命名规范：与 Name 保持一致
  # 工作原理：
  #   - 服务启动时在 Etcd 的 /Key/服务实例ID 路径下注册
  #   - 存储服务的地址、端口等信息
  #   - 客户端通过这个 Key 查询所有可用实例
  # 示例：
  #   Key: im.rpc
  #   实际注册路径：/im.rpc/192.168.117.24:10002
  Key: im.rpc

# ----------------------------------------------------------------------------
# MongoDB 数据库配置
# ----------------------------------------------------------------------------
# Mongo: MongoDB 数据库连接配置
# 作用：配置 IM 服务使用的 MongoDB 数据库
# 为什么使用 MongoDB：
#   - 适合存储非结构化的聊天消息
#   - 支持灵活的文档结构
#   - 高性能的读写能力
#   - 支持水平扩展
# IM 服务使用 MongoDB 存储：
#   - 聊天消息记录
#   - 会话信息
#   - 消息状态（已读/未读）
Mongo:
  # Url: MongoDB 连接字符串
  # 格式：mongodb://用户名:密码@主机:端口
  # 参数说明：
  #   - mongodb://: 协议前缀
  #   - root: 数据库用户名
  #   - easy-chat: 数据库密码
  #   - 192.168.117.24:47017: MongoDB 服务器地址和端口
  # 连接选项（可选）：
  #   - ?authSource=admin: 指定认证数据库
  #   - &maxPoolSize=100: 连接池大小
  #   - &minPoolSize=10: 最小连接数
  # 安全建议：
  #   - 生产环境使用强密码
  #   - 限制数据库用户权限
  #   - 启用 SSL/TLS 加密连接
  Url: "mongodb://root:easy-chat@192.168.117.24:47017"

  # Db: 数据库名称
  # 作用：指定使用的数据库
  # 命名规范：使用小写字母和连字符
  # 数据库结构：
  #   easy-chat 数据库包含多个集合（Collection）：
  #   - messages: 消息记录
  #   - conversations: 会话信息
  #   - message_status: 消息状态
  Db: easy-chat

# ============================================================================
# IM RPC 服务功能说明
# ============================================================================
# IM RPC 服务提供的主要功能：
#
# 1. 消息管理：
#    - SendMessage: 发送消息
#    - GetMessages: 获取消息列表
#    - GetMessageById: 根据 ID 获取消息
#    - DeleteMessage: 删除消息
#
# 2. 会话管理：
#    - GetConversations: 获取会话列表
#    - GetConversationById: 获取会话详情
#    - UpdateConversation: 更新会话信息
#
# 3. 消息状态：
#    - MarkAsRead: 标记消息为已读
#    - GetUnreadCount: 获取未读消息数
#
# 4. 消息推送：
#    - PushMessage: 推送消息到客户端
#    - BatchPushMessage: 批量推送消息
#
# ============================================================================
# 数据存储设计
# ============================================================================
# MongoDB 集合设计示例：
#
# 1. messages 集合（消息记录）：
#    {
#      "_id": ObjectId("..."),
#      "conversation_id": "conv_123",
#      "from_user_id": "user_001",
#      "to_user_id": "user_002",
#      "content": "Hello",
#      "msg_type": 1,  // 1:文本 2:图片 3:语音 4:视频
#      "send_time": ISODate("2024-01-01T12:00:00Z"),
#      "status": 1,  // 1:已发送 2:已送达 3:已读
#      "created_at": ISODate("2024-01-01T12:00:00Z")
#    }
#
# 2. conversations 集合（会话信息）：
#    {
#      "_id": "conv_123",
#      "type": 1,  // 1:单聊 2:群聊
#      "members": ["user_001", "user_002"],
#      "last_message": "Hello",
#      "last_message_time": ISODate("2024-01-01T12:00:00Z"),
#      "unread_count": {
#        "user_001": 0,
#        "user_002": 5
#      },
#      "created_at": ISODate("2024-01-01T10:00:00Z"),
#      "updated_at": ISODate("2024-01-01T12:00:00Z")
#    }
#
# ============================================================================
# 服务启动流程
# ============================================================================
# 1. 读取配置文件
#    - 解析 YAML 配置
#    - 验证配置项
#
# 2. 初始化数据库连接
#    - 连接 MongoDB
#    - 创建连接池
#    - 验证数据库连接
#
# 3. 注册到 Etcd
#    - 连接 Etcd
#    - 注册服务信息（地址、端口）
#    - 启动心跳保持
#
# 4. 启动 gRPC 服务
#    - 监听指定端口
#    - 注册 RPC 方法
#    - 等待客户端连接
#
# 5. 服务就绪
#    - 开始接收和处理 RPC 请求
#
# ============================================================================
# 开发环境使用指南
# ============================================================================
# 1. 启动前准备：
#    # 确保 Etcd 服务运行
#    curl http://192.168.117.24:3379/health
#
#    # 确保 MongoDB 服务运行
#    mongo mongodb://root:easy-chat@192.168.117.24:47017
#
#    # 确保端口 10002 未被占用
#    lsof -i:10002
#
# 2. 启动服务：
#    cd /home/lfl/easy-chat1/apps/im/rpc
#    go run im.go -f etc/dev/im.yaml
#
# 3. 验证服务注册：
#    # 使用 etcdctl 查看注册信息
#    etcdctl get --prefix /im.rpc
#
# 4. 测试 RPC 调用：
#    # 使用 grpcurl 测试（需要安装 grpcurl）
#    grpcurl -plaintext 192.168.117.24:10002 list
#
# ============================================================================
# 性能优化建议
# ============================================================================
# 1. MongoDB 优化：
#    - 为常用查询字段创建索引
#    - 使用复合索引优化复杂查询
#    - 配置合适的连接池大小
#    - 启用 MongoDB 的读写分离
#
# 2. gRPC 优化：
#    - 启用连接复用
#    - 使用流式 RPC 处理大量数据
#    - 配置合适的超时时间
#    - 启用 gRPC 压缩
#
# 3. 并发优化：
#    - 使用 goroutine 池控制并发数
#    - 避免阻塞操作
#    - 使用异步处理提高吞吐量
#
# 4. 缓存策略：
#    - 缓存热点数据（如最近消息）
#    - 使用 Redis 缓存会话信息
#    - 实现多级缓存
#
# ============================================================================
# 监控和日志
# ============================================================================
# 1. 关键指标监控：
#    - RPC 请求量和响应时间
#    - MongoDB 连接数和查询性能
#    - 服务 CPU 和内存使用率
#    - 错误率和超时率
#
# 2. 日志记录：
#    - 记录所有 RPC 请求和响应
#    - 记录数据库操作
#    - 记录错误和异常
#    - 使用结构化日志便于分析
#
# 3. 告警设置：
#    - 服务不可用告警
#    - 响应时间过长告警
#    - 错误率过高告警
#    - 数据库连接异常告警
#
# ============================================================================
# 常见问题和解决方案
# ============================================================================
# 1. 服务注册失败：
#    问题：无法连接 Etcd
#    解决：
#      - 检查 Etcd 服务状态
#      - 验证网络连接
#      - 检查防火墙规则
#
# 2. MongoDB 连接失败：
#    问题：认证失败或连接超时
#    解决：
#      - 验证用户名密码
#      - 检查 MongoDB 服务状态
#      - 检查网络连接和防火墙
#
# 3. RPC 调用超时：
#    问题：客户端调用超时
#    解决：
#      - 检查服务是否正常运行
#      - 优化数据库查询性能
#      - 增加超时时间配置
#
# 4. 内存占用过高：
#    问题：服务内存持续增长
#    解决：
#      - 检查是否有内存泄漏
#      - 优化数据结构
#      - 及时释放资源
#      - 配置合理的连接池大小
# ============================================================================
