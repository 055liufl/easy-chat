# ============================================================================
# User RPC 服务配置文件（开发环境）- 中文详细注释版本
# ============================================================================
# 文件说明：
#   这是 User RPC 服务的开发环境配置文件
#   使用 Go-Zero 推荐的大写驼峰命名风格
#   包含完整的服务配置
# ============================================================================

# Name: 服务名称
Name: user.rpc

# ListenOn: RPC 服务监听地址
ListenOn: 0.0.0.0:10000

# ----------------------------------------------------------------------------
# 服务注册与发现配置
# ----------------------------------------------------------------------------
Etcd:
  Hosts:
    - 192.168.117.24:3379
  Key: user.rpc

# ----------------------------------------------------------------------------
# MySQL 数据库配置
# ----------------------------------------------------------------------------
Mysql:
  # DataSource: MySQL 连接字符串
  # 注意：这里没有 parseTime=true 参数
  #       如果需要自动解析 time.Time 类型，建议添加：
  #       ?charset=utf8mb4&parseTime=true
  DataSource: root:easy-chat@tcp(192.168.117.24:13306)/easy-chat?charset=utf8mb4

# ----------------------------------------------------------------------------
# Redis 缓存配置
# ----------------------------------------------------------------------------
# Redisx: 自定义 Redis 配置
Redisx:
  Host: 192.168.117.24:16379
  Type: node
  Pass: easy-chat

# Cache: Go-Zero 标准缓存配置
Cache:
  - Host: 192.168.117.24:16379
    Type: node
    Pass: easy-chat

# ----------------------------------------------------------------------------
# JWT 配置
# ----------------------------------------------------------------------------
Jwt:
  # AccessSecret: JWT 签名密钥
  AccessSecret: imooc.com

  # AccessExpire: JWT token 过期时间（秒）
  # 8640000 秒 = 100 天
  AccessExpire: 8640000

# ============================================================================
# 配置说明
# ============================================================================
# 本配置文件是开发环境的完整配置
# 包含了 User RPC 服务运行所需的所有配置项
#
# 配置特点：
#   1. 使用大写驼峰命名（Go-Zero 推荐）
#   2. 包含 MySQL、Redis、JWT 完整配置
#   3. 同时配置了 Redisx 和 Cache（兼容不同用途）
#
# 启动命令：
#   go run user.go -f etc/dev/user.yaml
# ============================================================================
