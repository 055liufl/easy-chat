# ============================================================================
# User API 服务配置文件（开发环境）- 中文详细注释版本
# ============================================================================
# 文件说明：
#   这是 User API 服务的开发环境配置文件
#   使用 Go-Zero 推荐的大写驼峰命名风格
# ============================================================================

# Name: 服务名称
Name: user

# Host: 服务监听地址
Host: 0.0.0.0

# Port: 服务监听端口
Port: 8888

# ----------------------------------------------------------------------------
# Redis 缓存配置
# ----------------------------------------------------------------------------
Redisx:
  # Host: Redis 服务器地址
  Host: 192.168.117.24:16379

  # Pass: Redis 密码
  Pass: easy-chat

# ----------------------------------------------------------------------------
# RPC 服务依赖配置
# ----------------------------------------------------------------------------
UserRpc:
  Etcd:
    Hosts:
      - 192.168.117.24:3379
    Key: user.rpc

# ----------------------------------------------------------------------------
# JWT 认证配置
# ----------------------------------------------------------------------------
JwtAuth:
  # AccessSecret: JWT 签名密钥
  AccessSecret: imooc.com

  # AccessExpire: JWT token 过期时间
  # 单位：秒
  # 8640000 秒 = 100 天
  AccessExpire: 8640000

# ============================================================================
# 配置说明
# ============================================================================
# 本配置文件是开发环境的完整配置
# 包含了 User API 服务运行所需的所有配置项
#
# 与 conf/user-api.yaml 的区别：
#   1. 使用大写驼峰命名（推荐）
#   2. 没有 database 配置项
#   3. 配置项更清晰
#
# 启动命令：
#   go run user.go -f etc/dev/user.yaml
# ============================================================================
