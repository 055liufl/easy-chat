#!/bin/bash
# ============================================================================
# 脚本名称: social-rpc-test.sh
# 脚本用途: 部署 Social RPC 测试环境服务
# 所属模块: deploy/script
# ============================================================================

# 【脚本整体说明】
# 这是一个用于部署 Social（社交）RPC 服务到测试环境的 Docker 部署脚本。
# Social RPC 服务是微服务架构中的核心服务，提供社交相关的 gRPC 接口，包括：
# 1. 好友关系的 CRUD 操作
# 2. 好友申请的处理逻辑
# 3. 群组管理的业务逻辑
# 4. 供其他微服务（API、IM）调用
#
# 【使用场景】
# - 测试环境部署或更新 Social RPC 服务
# - 微服务架构中的内部服务
# - 提供 gRPC 接口供其他服务调用
#
# 【执行方式】
# 在 deploy/script 目录下执行：
#   bash social-rpc-test.sh
# 或者：
#   ./social-rpc-test.sh  (需要先 chmod +x social-rpc-test.sh)
#
# 【前置要求】
# 1. 已安装 Docker
# 2. 已登录阿里云容器镜像仓库
# 3. 端口 10001 未被占用
# 4. 了解当前服务器的 IP 地址

# ============================================================================
# 配置变量定义
# ============================================================================

# 【变量 1: 镜像仓库地址】
reso_addr='registry.cn-hangzhou.aliyuncs.com/easy-chat/social-rpc-dev'
# 说明：
# - registry.cn-hangzhou.aliyuncs.com: 阿里云杭州地域容器镜像服务
# - easy-chat: 命名空间
# - social-rpc-dev: Social RPC 服务的开发/测试环境镜像仓库

# 【变量 2: 镜像标签】
tag='latest'
# 说明：
# - latest: 始终拉取最新版本
# - 生产环境建议使用具体版本号

# 【变量 3: POD IP 地址】
pod_ip="192.168.117.24"
# 说明：
# - 当前服务器的 IP 地址
# - 用于服务注册到注册中心（如 etcd）
# - 其他服务通过此 IP 调用 Social RPC 服务
# - 重要：部署到不同服务器时，必须修改此 IP

# 【变量 4: 容器名称】
container_name="easy-chat-social-rpc-test"
# 说明：
# - 容器的唯一标识名称
# - 命名规范：项目名-服务名-环境

# ============================================================================
# 步骤 1: 停止运行中的容器
# ============================================================================
docker stop ${container_name}

# 【命令详解】
# 停止名为 easy-chat-social-rpc-test 的容器
# - 发送 SIGTERM 信号，让容器优雅关闭
# - 如果容器不存在，会显示错误但不影响后续执行

# ============================================================================
# 步骤 2: 删除已停止的容器
# ============================================================================
docker rm ${container_name}

# 【命令详解】
# 删除已停止的容器实例
# - 释放容器占用的资源
# - 避免容器名称冲突

# ============================================================================
# 步骤 3: 删除本地镜像
# ============================================================================
docker rmi ${reso_addr}:${tag}

# 【命令详解】
# 删除本地的 social-rpc-dev:latest 镜像
# - 确保下一步拉取的是最新版本
# - 释放磁盘空间

# ============================================================================
# 步骤 4: 从远程仓库拉取最新镜像
# ============================================================================
docker pull ${reso_addr}:${tag}

# 【命令详解】
# 从阿里云镜像仓库拉取最新的 social-rpc-dev 镜像
# - 下载镜像的所有层
# - 保存到本地 Docker 镜像存储

# ============================================================================
# 步骤 5: 启动新容器
# ============================================================================

# 【注释说明：自定义配置方式】
# 如果需要指定配置文件的
# docker run -p 10001:8080 --network imooc_easy-im -v /easy-im/config/user-rpc:/user/conf/ --name=${container_name} -d ${reso_addr}:${tag}

# 【实际执行的启动命令】
docker run -p 10001:10001 -e POD_IP=${pod_ip}  --name=${container_name} -d ${reso_addr}:${tag}

# 【命令详解】
# docker run: 创建并启动一个新容器
#
# 【参数说明】
# -p 10001:10001
#   - 端口映射：宿主机 10001 → 容器 10001
#   - 10001 是 Social RPC 服务监听的 gRPC 端口
#   - 其他服务通过 192.168.117.24:10001 调用此服务
#
# -e POD_IP=${pod_ip}
#   - 设置环境变量 POD_IP=192.168.117.24
#   - 用于服务注册到 etcd
#   - 注册地址：192.168.117.24:10001
#
# --name=${container_name}
#   - 指定容器名称：easy-chat-social-rpc-test
#
# -d
#   - detach 模式（后台运行）
#
# ${reso_addr}:${tag}
#   - 指定要运行的镜像

# ============================================================================
# 【Social RPC 服务功能】
# ============================================================================
# 1. 好友关系管理：
#    - rpc AddFriend(AddFriendReq) returns (AddFriendResp)
#      * 创建双向好友关系
#      * 更新好友申请状态
#    - rpc DeleteFriend(DeleteFriendReq) returns (DeleteFriendResp)
#      * 删除双向好友关系
#      * 清除相关缓存
#    - rpc GetFriendList(GetFriendListReq) returns (GetFriendListResp)
#      * 查询用户的好友列表
#      * 支持分页
#      * 使用缓存提高性能
#    - rpc IsFriend(IsFriendReq) returns (IsFriendResp)
#      * 判断两个用户是否为好友关系
#
# 2. 好友申请管理：
#    - rpc SendFriendApply(SendFriendApplyReq) returns (SendFriendApplyResp)
#      * 发送好友申请
#      * 检查是否已经是好友
#      * 检查是否已发送过申请
#    - rpc AcceptFriendApply(AcceptFriendApplyReq) returns (AcceptFriendApplyResp)
#      * 接受好友申请
#      * 创建好友关系
#      * 更新申请状态
#    - rpc RejectFriendApply(RejectFriendApplyReq) returns (RejectFriendApplyResp)
#      * 拒绝好友申请
#      * 更新申请状态
#    - rpc GetFriendApplyList(GetFriendApplyListReq) returns (GetFriendApplyListResp)
#      * 获取收到的好友申请列表
#      * 支持分页
#
# 3. 群组管理：
#    - rpc CreateGroup(CreateGroupReq) returns (CreateGroupResp)
#      * 创建群组
#      * 创建者自动成为群主
#    - rpc JoinGroup(JoinGroupReq) returns (JoinGroupResp)
#      * 加入群组
#      * 检查群组是否存在
#      * 检查是否已经是成员
#    - rpc QuitGroup(QuitGroupReq) returns (QuitGroupResp)
#      * 退出群组
#      * 如果是群主，需要转让或解散群组
#    - rpc DismissGroup(DismissGroupReq) returns (DismissGroupResp)
#      * 解散群组（仅群主）
#      * 删除所有成员关系
#    - rpc GetGroupList(GetGroupListReq) returns (GetGroupListResp)
#      * 获取用户加入的群组列表
#    - rpc GetGroupMembers(GetGroupMembersReq) returns (GetGroupMembersResp)
#      * 获取群组成员列表
#      * 支持分页
#
# 4. 群组成员管理：
#    - rpc InviteGroupMember(InviteGroupMemberReq) returns (InviteGroupMemberResp)
#      * 邀请用户加入群组
#    - rpc KickGroupMember(KickGroupMemberReq) returns (KickGroupMemberResp)
#      * 踢出群组成员（需要管理员权限）
#    - rpc SetGroupMemberRole(SetGroupMemberRoleReq) returns (SetGroupMemberRoleResp)
#      * 设置成员角色（群主、管理员、普通成员）

# ============================================================================
# 【数据库设计】
# ============================================================================
# 1. friend 表（好友关系表）：
#    - id: 主键
#    - user_id: 用户 ID
#    - friend_id: 好友 ID
#    - created_at: 创建时间
#    - 索引：(user_id, friend_id) 唯一索引
#    - 注意：好友关系是双向的，需要插入两条记录
#
# 2. friend_apply 表（好友申请表）：
#    - id: 主键
#    - from_user_id: 申请人 ID
#    - to_user_id: 被申请人 ID
#    - message: 申请消息
#    - status: 状态（0:待处理, 1:已接受, 2:已拒绝）
#    - created_at: 创建时间
#    - updated_at: 更新时间
#
# 3. group 表（群组表）：
#    - id: 主键
#    - name: 群组名称
#    - avatar: 群组头像
#    - owner_id: 群主 ID
#    - member_count: 成员数量
#    - max_member_count: 最大成员数量
#    - created_at: 创建时间
#
# 4. group_member 表（群组成员表）：
#    - id: 主键
#    - group_id: 群组 ID
#    - user_id: 用户 ID
#    - role: 角色（1:群主, 2:管理员, 3:普通成员）
#    - joined_at: 加入时间
#    - 索引：(group_id, user_id) 唯一索引

# ============================================================================
# 【业务逻辑说明】
# ============================================================================
# 1. 添加好友的事务处理：
#    BEGIN TRANSACTION
#      - 检查好友申请是否存在
#      - 更新好友申请状态为已接受
#      - 插入好友关系（user_id, friend_id）
#      - 插入好友关系（friend_id, user_id）双向关系
#      - 清除相关缓存
#    COMMIT
#
# 2. 删除好友的事务处理：
#    BEGIN TRANSACTION
#      - 删除好友关系（user_id, friend_id）
#      - 删除好友关系（friend_id, user_id）
#      - 清除相关缓存
#    COMMIT
#
# 3. 创建群组的事务处理：
#    BEGIN TRANSACTION
#      - 插入群组记录
#      - 插入群组成员记录（创建者为群主）
#      - 更新群组成员数量
#    COMMIT
#
# 4. 解散群组的事务处理：
#    BEGIN TRANSACTION
#      - 检查是否为群主
#      - 删除所有群组成员记录
#      - 删除群组记录
#      - 清除相关缓存
#    COMMIT

# ============================================================================
# 【缓存策略】
# ============================================================================
# 1. 好友列表缓存：
#    - 缓存键：social:friend:list:{userId}
#    - 缓存内容：好友 ID 列表
#    - 过期时间：1 小时
#    - 更新时机：添加/删除好友时清除
#
# 2. 好友关系缓存：
#    - 缓存键：social:friend:relation:{userId}:{friendId}
#    - 缓存内容：是否为好友（true/false）
#    - 过期时间：1 小时
#    - 更新时机：添加/删除好友时清除
#
# 3. 群组成员列表缓存：
#    - 缓存键：social:group:members:{groupId}
#    - 缓存内容：成员 ID 列表
#    - 过期时间：30 分钟
#    - 更新时机：成员加入/退出时清除
#
# 4. 用户群组列表缓存：
#    - 缓存键：social:group:list:{userId}
#    - 缓存内容：群组 ID 列表
#    - 过期时间：30 分钟
#    - 更新时机：加入/退出群组时清除

# ============================================================================
# 【服务注册与发现】
# ============================================================================
# 1. 服务注册：
#    - 启动时向 etcd 注册
#    - 注册信息：
#      * 服务名：easy-chat.social.rpc
#      * 地址：192.168.117.24:10001
#      * 权重：100
#
# 2. 健康检查：
#    - etcd 定期检查服务健康状态
#    - 如果服务不可用，自动从注册中心移除
#
# 3. 服务发现：
#    - 客户端从 etcd 获取服务地址列表
#    - 选择一个地址进行调用
#    - 支持负载均衡

# ============================================================================
# 【部署后的操作建议】
# ============================================================================
# 1. 查看容器状态：
#    docker ps | grep easy-chat-social-rpc-test
#
# 2. 查看容器日志：
#    docker logs -f easy-chat-social-rpc-test
#
# 3. 检查环境变量：
#    docker exec easy-chat-social-rpc-test env | grep POD_IP
#
# 4. 测试 gRPC 服务：
#    grpcurl -plaintext 192.168.117.24:10001 list
#    grpcurl -plaintext 192.168.117.24:10001 list social.Social
#
# 5. 检查服务注册：
#    docker exec -it etcd etcdctl get --prefix /easy-chat/social-rpc
#
# 6. 查看端口监听：
#    netstat -tlnp | grep 10001

# ============================================================================
# 【注意事项】
# ============================================================================
# 1. IP 地址配置：
#    - 必须修改 pod_ip 为实际服务器 IP
#    - 不能使用 127.0.0.1
#
# 2. 端口冲突：
#    - 确保 10001 端口未被占用
#    - 检查命令：netstat -tlnp | grep 10001
#
# 3. 依赖服务：
#    - 确保 etcd 已启动
#    - 确保 MySQL 数据库可访问
#    - 确保 Redis 可访问
#
# 4. 数据库初始化：
#    - 确保数据库表已创建
#    - 执行 SQL 脚本：deploy/sql/social.sql
#
# 5. 数据一致性：
#    - 好友关系必须是双向的
#    - 使用事务保证数据一致性
#    - 删除好友时必须删除双向关系

# ============================================================================
# 【故障排查】
# ============================================================================
# 1. 服务无法启动：
#    - 查看日志：docker logs easy-chat-social-rpc-test
#    - 检查端口占用
#    - 检查配置文件
#
# 2. 服务注册失败：
#    - 检查 etcd 是否可访问
#    - 检查 POD_IP 是否正确
#    - 查看服务启动日志
#
# 3. 数据库连接失败：
#    - 检查数据库是否启动
#    - 检查数据库连接配置
#    - 检查网络连通性
#
# 4. 好友关系异常：
#    - 检查数据库数据一致性
#    - 检查是否有孤立的好友关系
#    - 使用 SQL 查询验证

# ============================================================================
# 【端口分配说明】
# ============================================================================
# User RPC: 10000
# Social RPC: 10001
# IM RPC: 10002
# IM WS: 10090
# User API: 8888
# Social API: 8881
# IM API: 8882

# ============================================================================
# 【执行流程总结】
# ============================================================================
# 1. 停止旧容器 → 2. 删除旧容器 → 3. 删除旧镜像
# 4. 拉取新镜像 → 5. 启动新容器（带 POD_IP）
# 6. 服务启动 → 7. 注册到 etcd → 8. 等待其他服务调用
