#!/bin/bash
# ============================================================================
# 脚本名称: user-rpc-test.sh
# 脚本用途: 部署 User RPC 测试环境服务
# 所属模块: deploy/script
# ============================================================================

# 【脚本整体说明】
# 这是一个用于部署 User（用户）RPC 服务到测试环境的 Docker 部署脚本。
# User RPC 服务是微服务架构中的核心服务，提供用户相关的 gRPC 接口，包括：
# 1. 用户数据的 CRUD 操作
# 2. 用户认证和授权逻辑
# 3. 用户信息查询和更新
# 4. 供其他微服务（API、IM、Social）调用
#
# 【使用场景】
# - 测试环境部署或更新 User RPC 服务
# - 微服务架构中的内部服务
# - 提供 gRPC 接口供其他服务调用
#
# 【执行方式】
# 在 deploy/script 目录下执行：
#   bash user-rpc-test.sh
# 或者：
#   ./user-rpc-test.sh  (需要先 chmod +x user-rpc-test.sh)
#
# 【前置要求】
# 1. 已安装 Docker
# 2. 已登录阿里云容器镜像仓库
# 3. 端口 10000 未被占用
# 4. 了解当前服务器的 IP 地址

# ============================================================================
# 配置变量定义
# ============================================================================

# 【变量 1: 镜像仓库地址】
reso_addr='registry.cn-hangzhou.aliyuncs.com/easy-chat/user-rpc-dev'
# 说明：
# - registry.cn-hangzhou.aliyuncs.com: 阿里云杭州地域容器镜像服务
# - easy-chat: 命名空间
# - user-rpc-dev: User RPC 服务的开发/测试环境镜像仓库

# 【变量 2: 镜像标签】
tag='latest'
# 说明：
# - latest: 始终拉取最新版本
# - 生产环境建议使用具体版本号

# 【变量 3: POD IP 地址】
pod_ip="192.168.117.24"
# 说明：
# - 当前服务器的 IP 地址
# - 用于服务注册到注册中心（如 etcd）
# - 其他服务通过此 IP 调用 User RPC 服务
# - 重要：部署到不同服务器时，必须修改此 IP

# 【变量 4: 容器名称】
container_name="easy-chat-user-rpc-test"
# 说明：
# - 容器的唯一标识名称
# - 命名规范：项目名-服务名-环境

# ============================================================================
# 步骤 1: 停止运行中的容器
# ============================================================================
docker stop ${container_name}

# 【命令详解】
# 停止名为 easy-chat-user-rpc-test 的容器
# - 发送 SIGTERM 信号，让容器优雅关闭
# - 如果容器不存在，会显示错误但不影响后续执行

# ============================================================================
# 步骤 2: 删除已停止的容器
# ============================================================================
docker rm ${container_name}

# 【命令详解】
# 删除已停止的容器实例
# - 释放容器占用的资源
# - 避免容器名称冲突

# ============================================================================
# 步骤 3: 删除本地镜像
# ============================================================================
docker rmi ${reso_addr}:${tag}

# 【命令详解】
# 删除本地的 user-rpc-dev:latest 镜像
# - 确保下一步拉取的是最新版本
# - 释放磁盘空间

# ============================================================================
# 步骤 4: 从远程仓库拉取最新镜像
# ============================================================================
docker pull ${reso_addr}:${tag}

# 【命令详解】
# 从阿里云镜像仓库拉取最新的 user-rpc-dev 镜像
# - 下载镜像的所有层
# - 保存到本地 Docker 镜像存储

# ============================================================================
# 步骤 5: 启动新容器
# ============================================================================

# 【注释说明：自定义配置方式】
# 如果需要指定配置文件的
# docker run -p 10001:8080 --network imooc_easy-im -v /easy-im/config/user-rpc:/user/conf/ --name=${container_name} -d ${reso_addr}:${tag}

# 【实际执行的启动命令】
docker run -p 10000:10000 -e POD_IP=${pod_ip}  --name=${container_name} -d ${reso_addr}:${tag}

# 【命令详解】
# docker run: 创建并启动一个新容器
#
# 【参数说明】
# -p 10000:10000
#   - 端口映射：宿主机 10000 → 容器 10000
#   - 10000 是 User RPC 服务监听的 gRPC 端口
#   - 其他服务通过 192.168.117.24:10000 调用此服务
#
# -e POD_IP=${pod_ip}
#   - 设置环境变量 POD_IP=192.168.117.24
#   - 用于服务注册到 etcd
#   - 注册地址：192.168.117.24:10000
#
# --name=${container_name}
#   - 指定容器名称：easy-chat-user-rpc-test
#
# -d
#   - detach 模式（后台运行）
#
# ${reso_addr}:${tag}
#   - 指定要运行的镜像

# ============================================================================
# 【User RPC 服务功能】
# ============================================================================
# 1. 用户注册：
#    - rpc Register(RegisterReq) returns (RegisterResp)
#    - 创建新用户记录
#    - 密码加密存储
#    - 返回用户 ID
#
# 2. 用户登录：
#    - rpc Login(LoginReq) returns (LoginResp)
#    - 验证用户名和密码
#    - 生成 token
#    - 返回用户信息和 token
#
# 3. 获取用户信息：
#    - rpc GetUserInfo(GetUserInfoReq) returns (GetUserInfoResp)
#    - 根据用户 ID 查询用户信息
#    - 支持批量查询
#    - 使用缓存提高性能
#
# 4. 更新用户信息：
#    - rpc UpdateUserInfo(UpdateUserInfoReq) returns (UpdateUserInfoResp)
#    - 更新用户资料（昵称、头像、签名等）
#    - 清除相关缓存
#
# 5. 修改密码：
#    - rpc ChangePassword(ChangePasswordReq) returns (ChangePasswordResp)
#    - 验证旧密码
#    - 更新新密码
#
# 6. 用户搜索：
#    - rpc SearchUser(SearchUserReq) returns (SearchUserResp)
#    - 根据关键词搜索用户
#    - 支持模糊匹配
#
# 7. 验证 Token：
#    - rpc VerifyToken(VerifyTokenReq) returns (VerifyTokenResp)
#    - 验证 token 有效性
#    - 返回用户信息

# ============================================================================
# 【RPC 服务架构】
# ============================================================================
# 1. 服务调用流程：
#    User API → User RPC → 数据库/缓存
#    IM API → User RPC → 数据库/缓存
#    Social API → User RPC → 数据库/缓存
#
# 2. 分层架构：
#    - Server 层：gRPC 服务器，接收请求
#    - Logic 层：业务逻辑处理
#    - Model 层：数据库操作（带缓存）
#
# 3. 数据库操作：
#    - 使用 GORM 或 sqlx 操作数据库
#    - 支持事务处理
#    - 连接池管理
#
# 4. 缓存策略：
#    - 使用 Redis 缓存用户信息
#    - 缓存键：user:info:{userId}
#    - 缓存过期时间：1 小时
#    - 更新时清除缓存

# ============================================================================
# 【服务注册与发现】
# ============================================================================
# 1. 服务注册：
#    - 启动时向 etcd 注册
#    - 注册信息：
#      * 服务名：easy-chat.user.rpc
#      * 地址：192.168.117.24:10000
#      * 权重：100
#      * 元数据：版本、环境等
#
# 2. 健康检查：
#    - etcd 定期检查服务健康状态
#    - 如果服务不可用，自动从注册中心移除
#    - 服务恢复后自动重新注册
#
# 3. 服务发现：
#    - 客户端从 etcd 获取服务地址列表
#    - 选择一个地址进行调用
#    - 支持负载均衡
#
# 4. 负载均衡：
#    - 轮询（Round Robin）
#    - 随机（Random）
#    - 权重（Weighted）
#    - 最少连接（Least Connection）

# ============================================================================
# 【部署后的操作建议】
# ============================================================================
# 1. 查看容器状态：
#    docker ps | grep easy-chat-user-rpc-test
#
# 2. 查看容器日志：
#    docker logs -f easy-chat-user-rpc-test
#    # 检查服务是否成功启动
#    # 检查是否注册到 etcd
#
# 3. 检查环境变量：
#    docker exec easy-chat-user-rpc-test env | grep POD_IP
#
# 4. 测试 gRPC 服务：
#    # 使用 grpcurl 工具测试
#    grpcurl -plaintext 192.168.117.24:10000 list
#    grpcurl -plaintext 192.168.117.24:10000 list user.User
#
# 5. 检查服务注册：
#    docker exec -it etcd etcdctl get --prefix /easy-chat/user-rpc
#
# 6. 查看端口监听：
#    netstat -tlnp | grep 10000

# ============================================================================
# 【注意事项】
# ============================================================================
# 1. IP 地址配置：
#    - 必须修改 pod_ip 为实际服务器 IP
#    - 不能使用 127.0.0.1
#
# 2. 端口冲突：
#    - 确保 10000 端口未被占用
#    - 检查命令：netstat -tlnp | grep 10000
#
# 3. 依赖服务：
#    - 确保 etcd 已启动
#    - 确保 MySQL 数据库可访问
#    - 确保 Redis 可访问
#
# 4. 数据库初始化：
#    - 确保数据库表已创建
#    - 执行 SQL 脚本：deploy/sql/user.sql
#
# 5. 防火墙规则：
#    - 如果有防火墙，需要开放 10000 端口
#    - 允许其他服务器访问此端口

# ============================================================================
# 【故障排查】
# ============================================================================
# 1. 服务无法启动：
#    - 查看日志：docker logs easy-chat-user-rpc-test
#    - 检查端口占用
#    - 检查配置文件
#
# 2. 服务注册失败：
#    - 检查 etcd 是否可访问
#    - 检查 POD_IP 是否正确
#    - 查看服务启动日志
#
# 3. 数据库连接失败：
#    - 检查数据库是否启动
#    - 检查数据库连接配置
#    - 检查网络连通性
#
# 4. 其他服务无法调用：
#    - 检查服务是否注册到 etcd
#    - 检查网络连通性
#    - 检查端口是否开放

# ============================================================================
# 【端口分配说明】
# ============================================================================
# User RPC: 10000
# Social RPC: 10001
# IM RPC: 10002
# IM WS: 10090
# User API: 8888
# Social API: 8881
# IM API: 8882

# ============================================================================
# 【执行流程总结】
# ============================================================================
# 1. 停止旧容器 → 2. 删除旧容器 → 3. 删除旧镜像
# 4. 拉取新镜像 → 5. 启动新容器（带 POD_IP）
# 6. 服务启动 → 7. 注册到 etcd → 8. 等待其他服务调用
