#!/bin/bash
# ============================================================================
# 脚本名称: task-mq-test.sh
# 脚本用途: 部署 Task MQ 测试环境服务
# 所属模块: deploy/script
# ============================================================================

# 【脚本整体说明】
# 这是一个用于部署 Task MQ（消息队列任务处理）服务到测试环境的 Docker 部署脚本。
# Task MQ 服务是异步任务处理服务，负责：
# 1. 消费消息队列中的任务消息
# 2. 处理异步任务（如发送邮件、推送通知、数据统计等）
# 3. 解耦业务逻辑，提高系统响应速度
# 4. 处理耗时操作，避免阻塞主业务流程
#
# 【使用场景】
# - 异步任务处理（发送邮件、短信、推送通知）
# - 数据同步和统计
# - 定时任务执行
# - 消息队列消费者
#
# 【执行方式】
# 在 deploy/script 目录下执行：
#   bash task-mq-test.sh
# 或者：
#   ./task-mq-test.sh  (需要先 chmod +x task-mq-test.sh)
#
# 【前置要求】
# 1. 已安装 Docker
# 2. 已登录阿里云容器镜像仓库
# 3. 消息队列服务（Kafka/RabbitMQ/Redis）已启动

# ============================================================================
# 配置变量定义
# ============================================================================

# 【变量 1: 镜像仓库地址】
reso_addr='registry.cn-hangzhou.aliyuncs.com/easy-chat/task-mq-dev'
# 说明：
# - registry.cn-hangzhou.aliyuncs.com: 阿里云杭州地域容器镜像服务
# - easy-chat: 命名空间
# - task-mq-dev: Task MQ 服务的开发/测试环境镜像仓库

# 【变量 2: 镜像标签】
tag='latest'
# 说明：
# - latest: 始终拉取最新版本
# - 生产环境建议使用具体版本号

# 【变量 3: 容器名称】
container_name="easy-chat-task-mq-test"
# 说明：
# - 容器的唯一标识名称
# - 命名规范：项目名-服务名-环境

# ============================================================================
# 步骤 1: 停止运行中的容器
# ============================================================================
docker stop ${container_name}

# 【命令详解】
# 停止名为 easy-chat-task-mq-test 的容器
# - 发送 SIGTERM 信号，让容器优雅关闭
# - Task MQ 服务会：
#   * 停止消费新消息
#   * 完成正在处理的任务
#   * 提交消息确认（ACK）
#   * 关闭消息队列连接
# - 如果容器不存在，会显示错误但不影响后续执行

# ============================================================================
# 步骤 2: 删除已停止的容器
# ============================================================================
docker rm ${container_name}

# 【命令详解】
# 删除已停止的容器实例
# - 释放容器占用的资源
# - 避免容器名称冲突

# ============================================================================
# 步骤 3: 删除本地镜像
# ============================================================================
docker rmi ${reso_addr}:${tag}

# 【命令详解】
# 删除本地的 task-mq-dev:latest 镜像
# - 确保下一步拉取的是最新版本
# - 释放磁盘空间

# ============================================================================
# 步骤 4: 从远程仓库拉取最新镜像
# ============================================================================
docker pull ${reso_addr}:${tag}

# 【命令详解】
# 从阿里云镜像仓库拉取最新的 task-mq-dev 镜像
# - 下载镜像的所有层
# - 保存到本地 Docker 镜像存储

# ============================================================================
# 步骤 5: 启动新容器
# ============================================================================

# 【注释说明：自定义配置方式】
# 如果需要指定配置文件的
# docker run -p 10001:8080 --network imooc_easy-im -v /easy-im/config/user-rpc:/user/conf/ --name=${container_name} -d ${reso_addr}:${tag}
#
# 【注释命令解析】
# - 这是一个示例，展示如何挂载外部配置文件
# - 当前未使用，因为配置已内置在镜像中
# - Task MQ 服务通常不需要对外暴露端口

# 【实际执行的启动命令】
docker run  --name=${container_name} -d ${reso_addr}:${tag}

# 【命令详解】
# docker run: 创建并启动一个新容器
#
# 【参数说明】
# --name=${container_name}
#   - 指定容器名称：easy-chat-task-mq-test
#   - 便于后续管理和查看日志
#
# -d
#   - detach 模式（后台运行）
#   - 容器在后台运行，不占用终端
#
# ${reso_addr}:${tag}
#   - 指定要运行的镜像
#   - 完整名称：registry.cn-hangzhou.aliyuncs.com/easy-chat/task-mq-dev:latest
#
# 【注意】
# - 没有 -p 参数：Task MQ 服务不需要对外暴露端口
# - 没有 -e POD_IP：Task MQ 服务通常不需要注册到服务中心
# - 服务启动后会自动连接消息队列并开始消费消息

# ============================================================================
# 【Task MQ 服务功能】
# ============================================================================
# 1. 消息推送任务：
#    - 消费主题：easy-chat.push.notification
#    - 任务内容：推送通知给用户
#    - 处理逻辑：
#      * 从消息队列获取推送任务
#      * 调用推送服务（极光推送、Firebase 等）
#      * 记录推送结果
#      * 确认消息（ACK）
#
# 2. 邮件发送任务：
#    - 消费主题：easy-chat.email.send
#    - 任务内容：发送邮件（注册验证、密码重置等）
#    - 处理逻辑：
#      * 从消息队列获取邮件任务
#      * 调用邮件服务（SMTP）
#      * 记录发送结果
#      * 确认消息
#
# 3. 短信发送任务：
#    - 消费主题：easy-chat.sms.send
#    - 任务内容：发送短信验证码
#    - 处理逻辑：
#      * 从消息队列获取短信任务
#      * 调用短信服务（阿里云、腾讯云等）
#      * 记录发送结果
#      * 确认消息
#
# 4. 数据统计任务：
#    - 消费主题：easy-chat.statistics
#    - 任务内容：统计用户活跃度、消息数量等
#    - 处理逻辑：
#      * 从消息队列获取统计任务
#      * 查询数据库进行统计
#      * 将结果写入统计表或缓存
#      * 确认消息
#
# 5. 消息同步任务：
#    - 消费主题：easy-chat.message.sync
#    - 任务内容：同步消息到搜索引擎（Elasticsearch）
#    - 处理逻辑：
#      * 从消息队列获取消息数据
#      * 格式化数据
#      * 写入 Elasticsearch
#      * 确认消息
#
# 6. 定时任务：
#    - 消费主题：easy-chat.cron.task
#    - 任务内容：执行定时任务（清理过期数据、生成报表等）
#    - 处理逻辑：
#      * 从消息队列获取定时任务
#      * 执行任务逻辑
#      * 记录执行结果
#      * 确认消息

# ============================================================================
# 【消息队列架构】
# ============================================================================
# 1. 生产者（Producer）：
#    - User API: 发送邮件任务
#    - IM API: 发送推送通知任务
#    - Social API: 发送好友申请通知任务
#
# 2. 消息队列（Message Queue）：
#    - Kafka: 高吞吐量，适合大规模消息处理
#    - RabbitMQ: 功能丰富，支持多种消息模式
#    - Redis: 轻量级，适合简单的消息队列场景
#
# 3. 消费者（Consumer）：
#    - Task MQ 服务: 消费消息并处理任务
#    - 支持多个实例并行消费（提高处理能力）
#
# 4. 消息格式：
#    {
#      "topic": "easy-chat.push.notification",
#      "key": "user_123",
#      "value": {
#        "userId": "123",
#        "title": "新消息",
#        "content": "你有一条新消息",
#        "type": "message"
#      },
#      "timestamp": 1234567890
#    }

# ============================================================================
# 【消息处理流程】
# ============================================================================
# 1. 消费消息：
#    - 从消息队列拉取消息
#    - 解析消息内容
#    - 验证消息格式
#
# 2. 处理任务：
#    - 根据消息类型调用相应的处理器
#    - 执行业务逻辑
#    - 调用外部服务（推送、邮件、短信等）
#
# 3. 错误处理：
#    - 如果处理失败，记录错误日志
#    - 根据错误类型决定是否重试
#    - 重试次数超过限制后，将消息放入死信队列
#
# 4. 确认消息：
#    - 处理成功后，发送 ACK 确认
#    - 消息队列删除该消息
#    - 如果不确认，消息会重新投递

# ============================================================================
# 【重试机制】
# ============================================================================
# 1. 自动重试：
#    - 处理失败时，自动重试
#    - 重试间隔：1秒、5秒、10秒、30秒、60秒
#    - 最大重试次数：5 次
#
# 2. 指数退避：
#    - 重试间隔逐渐增加
#    - 避免频繁重试导致系统压力
#
# 3. 死信队列：
#    - 重试次数超过限制后，放入死信队列
#    - 人工介入处理
#    - 或定期重新处理

# ============================================================================
# 【监控和告警】
# ============================================================================
# 1. 消费速率监控：
#    - 监控每秒消费的消息数量
#    - 如果消费速率过低，可能需要增加实例
#
# 2. 消息积压监控：
#    - 监控消息队列中的消息数量
#    - 如果消息积压严重，需要增加消费者
#
# 3. 处理失败率监控：
#    - 监控任务处理失败的比例
#    - 如果失败率过高，需要排查原因
#
# 4. 死信队列监控：
#    - 监控死信队列中的消息数量
#    - 定期处理死信消息
#
# 5. 告警规则：
#    - 消息积压超过 10000 条
#    - 处理失败率超过 5%
#    - 死信队列消息超过 100 条
#    - 消费者服务宕机

# ============================================================================
# 【部署后的操作建议】
# ============================================================================
# 1. 查看容器状态：
#    docker ps | grep easy-chat-task-mq-test
#
# 2. 查看容器日志：
#    docker logs -f easy-chat-task-mq-test
#    # 检查是否成功连接消息队列
#    # 检查是否开始消费消息
#    # 查看任务处理日志
#
# 3. 进入容器内部：
#    docker exec -it easy-chat-task-mq-test /bin/sh
#
# 4. 监控消息队列：
#    # Kafka
#    kafka-consumer-groups.sh --bootstrap-server localhost:9092 --describe --group easy-chat-task-mq
#
#    # RabbitMQ
#    rabbitmqctl list_queues
#
#    # Redis
#    redis-cli llen easy-chat:task:queue
#
# 5. 测试任务处理：
#    # 手动发送一条测试消息到消息队列
#    # 观察 Task MQ 服务是否正常消费和处理

# ============================================================================
# 【注意事项】
# ============================================================================
# 1. 消息队列连接：
#    - 确保消息队列服务已启动
#    - 检查连接配置（地址、端口、认证信息）
#    - 确保网络连通性
#
# 2. 幂等性：
#    - 任务处理必须保证幂等性
#    - 同一条消息可能被重复消费
#    - 使用唯一 ID 去重
#
# 3. 事务处理：
#    - 如果任务涉及数据库操作，使用事务
#    - 确保数据一致性
#
# 4. 资源限制：
#    - 控制并发处理的任务数量
#    - 避免消耗过多资源
#    - 建议添加：--memory=512m --cpus=1
#
# 5. 日志管理：
#    - 记录详细的任务处理日志
#    - 便于排查问题
#    - 配置日志轮转
#
# 6. 优雅关闭：
#    - 停止服务时，等待正在处理的任务完成
#    - 避免任务处理中断
#    - 设置合理的超时时间
#
# 7. 多实例部署：
#    - 可以部署多个 Task MQ 实例
#    - 提高任务处理能力
#    - 实现高可用
#    - 注意：每个实例使用不同的容器名称

# ============================================================================
# 【故障排查】
# ============================================================================
# 1. 服务无法启动：
#    - 查看日志：docker logs easy-chat-task-mq-test
#    - 检查配置文件
#    - 检查消息队列连接
#
# 2. 无法消费消息：
#    - 检查消息队列是否有消息
#    - 检查消费者组配置
#    - 检查网络连通性
#    - 查看错误日志
#
# 3. 任务处理失败：
#    - 查看错误日志
#    - 检查外部服务是否可用（推送、邮件、短信服务）
#    - 检查数据库连接
#    - 检查消息格式是否正确
#
# 4. 消息积压：
#    - 检查处理速度是否过慢
#    - 增加消费者实例
#    - 优化任务处理逻辑
#    - 检查是否有死循环或阻塞

# ============================================================================
# 【与其他服务的关系】
# ============================================================================
# 1. User API → 消息队列 → Task MQ
#    - User API 发送邮件任务到消息队列
#    - Task MQ 消费任务并发送邮件
#
# 2. IM API → 消息队列 → Task MQ
#    - IM API 发送推送通知任务到消息队列
#    - Task MQ 消费任务并推送通知
#
# 3. Social API → 消息队列 → Task MQ
#    - Social API 发送好友申请通知任务到消息队列
#    - Task MQ 消费任务并发送通知
#
# 4. Task MQ → 外部服务
#    - Task MQ 调用推送服务（极光推送、Firebase）
#    - Task MQ 调用邮件服务（SMTP）
#    - Task MQ 调用短信服务（阿里云、腾讯云）

# ============================================================================
# 【性能优化】
# ============================================================================
# 1. 批量处理：
#    - 一次消费多条消息
#    - 批量调用外部服务
#    - 提高处理效率
#
# 2. 并发处理：
#    - 使用协程或线程池
#    - 并发处理多个任务
#    - 注意控制并发数量
#
# 3. 连接池：
#    - 使用数据库连接池
#    - 使用 HTTP 连接池
#    - 复用连接，减少开销
#
# 4. 缓存：
#    - 缓存常用数据
#    - 减少数据库查询
#    - 提高处理速度

# ============================================================================
# 【执行流程总结】
# ============================================================================
# 1. 停止旧容器 → 2. 删除旧容器 → 3. 删除旧镜像
# 4. 拉取新镜像 → 5. 启动新容器
# 6. 服务启动 → 7. 连接消息队列 → 8. 开始消费消息 → 9. 处理任务
