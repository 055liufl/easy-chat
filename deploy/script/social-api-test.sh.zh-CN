#!/bin/bash
# ============================================================================
# 脚本名称: social-api-test.sh
# 脚本用途: 部署 Social API 测试环境服务
# 所属模块: deploy/script
# ============================================================================

# 【脚本整体说明】
# 这是一个用于部署 Social（社交）API 服务到测试环境的 Docker 部署脚本。
# Social API 服务提供社交相关的 HTTP 接口，包括：
# 1. 好友关系管理（添加、删除、查询好友）
# 2. 好友申请处理（发送、接受、拒绝）
# 3. 群组管理（创建、加入、退出群组）
# 4. 社交关系查询（共同好友、好友列表等）
#
# 【使用场景】
# - 测试环境部署或更新 Social API 服务
# - 提供社交功能相关的 RESTful API
# - 前端或移动端调用的社交服务接口
#
# 【执行方式】
# 在 deploy/script 目录下执行：
#   bash social-api-test.sh
# 或者：
#   ./social-api-test.sh  (需要先 chmod +x social-api-test.sh)
#
# 【前置要求】
# 1. 已安装 Docker
# 2. 已登录阿里云容器镜像仓库
# 3. 端口 8881 未被占用

# ============================================================================
# 配置变量定义
# ============================================================================

# 【变量 1: 镜像仓库地址】
reso_addr='registry.cn-hangzhou.aliyuncs.com/easy-chat/social-api-dev'
# 说明：
# - registry.cn-hangzhou.aliyuncs.com: 阿里云杭州地域容器镜像服务
# - easy-chat: 命名空间
# - social-api-dev: Social API 服务的开发/测试环境镜像仓库

# 【变量 2: 镜像标签】
tag='latest'
# 说明：
# - latest: 始终拉取最新版本
# - 生产环境建议使用具体版本号

# 【变量 3: 容器名称】
container_name="easy-chat-social-api-test"
# 说明：
# - 容器的唯一标识名称
# - 命名规范：项目名-服务名-环境

# ============================================================================
# 步骤 1: 停止运行中的容器
# ============================================================================
docker stop ${container_name}

# 【命令详解】
# 停止名为 easy-chat-social-api-test 的容器
# - 发送 SIGTERM 信号，让容器优雅关闭
# - 如果容器不存在，会显示错误但不影响后续执行

# ============================================================================
# 步骤 2: 删除已停止的容器
# ============================================================================
docker rm ${container_name}

# 【命令详解】
# 删除已停止的容器实例
# - 释放容器占用的资源
# - 避免容器名称冲突

# ============================================================================
# 步骤 3: 删除本地镜像
# ============================================================================
docker rmi ${reso_addr}:${tag}

# 【命令详解】
# 删除本地的 social-api-dev:latest 镜像
# - 确保下一步拉取的是最新版本
# - 释放磁盘空间

# ============================================================================
# 步骤 4: 从远程仓库拉取最新镜像
# ============================================================================
docker pull ${reso_addr}:${tag}

# 【命令详解】
# 从阿里云镜像仓库拉取最新的 social-api-dev 镜像
# - 下载镜像的所有层
# - 保存到本地 Docker 镜像存储

# ============================================================================
# 步骤 5: 启动新容器
# ============================================================================

# 【注释说明：自定义配置方式】
# 如果需要指定配置文件的
# docker run -p 10001:8080 --network imooc_easy-im -v /easy-im/config/user-rpc:/user/conf/ --name=${container_name} -d ${reso_addr}:${tag}

# 【实际执行的启动命令】
docker run -p 8881:8881  --name=${container_name} -d ${reso_addr}:${tag}

# 【命令详解】
# docker run: 创建并启动一个新容器
#
# 【参数说明】
# -p 8881:8881
#   - 端口映射：宿主机 8881 → 容器 8881
#   - 8881 是 Social API 服务监听的 HTTP 端口
#   - 客户端通过 http://服务器IP:8881 访问 API
#   - 例如：http://192.168.117.24:8881/api/friend/list
#
# --name=${container_name}
#   - 指定容器名称：easy-chat-social-api-test
#   - 便于后续管理和查看日志
#
# -d
#   - detach 模式（后台运行）
#   - 容器在后台运行，不占用终端
#
# ${reso_addr}:${tag}
#   - 指定要运行的镜像
#   - 完整名称：registry.cn-hangzhou.aliyuncs.com/easy-chat/social-api-dev:latest

# ============================================================================
# 【Social API 服务功能】
# ============================================================================
# 1. 好友管理：
#    - POST /api/friend/add - 添加好友（发送好友申请）
#    - DELETE /api/friend/delete - 删除好友
#    - GET /api/friend/list - 获取好友列表
#    - GET /api/friend/info - 获取好友信息
#
# 2. 好友申请：
#    - POST /api/friend/apply - 发送好友申请
#    - POST /api/friend/accept - 接受好友申请
#    - POST /api/friend/reject - 拒绝好友申请
#    - GET /api/friend/apply/list - 获取好友申请列表
#
# 3. 群组管理：
#    - POST /api/group/create - 创建群组
#    - POST /api/group/join - 加入群组
#    - POST /api/group/quit - 退出群组
#    - DELETE /api/group/dismiss - 解散群组
#    - GET /api/group/list - 获取群组列表
#    - GET /api/group/members - 获取群组成员
#
# 4. 群组成员管理：
#    - POST /api/group/invite - 邀请成员
#    - POST /api/group/kick - 踢出成员
#    - PUT /api/group/role - 设置成员角色（管理员、普通成员）
#
# 5. 社交关系查询：
#    - GET /api/friend/common - 查询共同好友
#    - GET /api/friend/recommend - 好友推荐
#    - GET /api/friend/search - 搜索好友

# ============================================================================
# 【API 服务架构】
# ============================================================================
# 1. 请求流程：
#    客户端 → Nginx（可选）→ Social API → Social RPC → 数据库
#
# 2. 分层架构：
#    - Handler 层：处理 HTTP 请求，参数验证
#    - Logic 层：业务逻辑处理
#    - RPC 层：调用 Social RPC 服务
#    - Model 层：数据库操作（在 RPC 服务中）
#
# 3. 认证授权：
#    - 使用 JWT token 进行认证
#    - 中间件验证 token 有效性
#    - 提取用户信息并传递给业务层
#
# 4. 数据库设计：
#    - friend 表：好友关系表
#    - friend_apply 表：好友申请表
#    - group 表：群组信息表
#    - group_member 表：群组成员表

# ============================================================================
# 【业务逻辑说明】
# ============================================================================
# 1. 添加好友流程：
#    - 用户 A 发送好友申请给用户 B
#    - 系统创建好友申请记录（状态：待处理）
#    - 通知用户 B（通过 WebSocket 或推送）
#    - 用户 B 接受申请
#    - 系统创建双向好友关系
#    - 更新申请状态为已接受
#    - 通知用户 A 申请已通过
#
# 2. 创建群组流程：
#    - 用户创建群组（设置群名、群头像等）
#    - 系统创建群组记录
#    - 创建者自动成为群主
#    - 可以邀请其他用户加入
#
# 3. 加入群组流程：
#    - 用户申请加入群组
#    - 群主或管理员审核
#    - 审核通过后，用户成为群成员
#    - 或者：群组设置为公开，无需审核直接加入

# ============================================================================
# 【部署后的操作建议】
# ============================================================================
# 1. 查看容器状态：
#    docker ps | grep easy-chat-social-api-test
#
# 2. 查看容器日志：
#    docker logs -f easy-chat-social-api-test
#
# 3. 测试 API 接口：
#    # 健康检查
#    curl http://localhost:8881/health
#
#    # 获取好友列表（需要 token）
#    curl -X GET http://localhost:8881/api/friend/list \
#      -H "Authorization: Bearer <token>"
#
#    # 添加好友
#    curl -X POST http://localhost:8881/api/friend/add \
#      -H "Authorization: Bearer <token>" \
#      -H "Content-Type: application/json" \
#      -d '{"friendId":"123","message":"你好，加个好友吧"}'
#
# 4. 查看 API 文档：
#    # 如果集成了 Swagger
#    http://localhost:8881/swagger/index.html
#
# 5. 进入容器内部：
#    docker exec -it easy-chat-social-api-test /bin/sh

# ============================================================================
# 【注意事项】
# ============================================================================
# 1. 端口冲突：
#    - 确保 8881 端口未被占用
#    - 检查命令：netstat -tlnp | grep 8881
#
# 2. 依赖服务：
#    - 确保 Social RPC 服务已启动
#    - 确保 User RPC 服务已启动（查询用户信息）
#    - 确保数据库、Redis 等依赖服务可访问
#
# 3. 数据一致性：
#    - 好友关系是双向的（A 是 B 的好友，B 也是 A 的好友）
#    - 删除好友时需要删除双向关系
#    - 使用事务保证数据一致性
#
# 4. 性能优化：
#    - 好友列表使用缓存（Redis）
#    - 群组成员列表使用缓存
#    - 分页查询，避免一次性加载大量数据
#
# 5. 安全性：
#    - 验证用户权限（只能操作自己的好友关系）
#    - 防止恶意添加好友（频率限制）
#    - 防止群组炸弹（限制群组数量和成员数量）

# ============================================================================
# 【故障排查】
# ============================================================================
# 1. 服务无法启动：
#    - 查看日志：docker logs easy-chat-social-api-test
#    - 检查端口占用
#    - 检查配置文件
#
# 2. API 调用失败：
#    - 检查 Social RPC 服务是否正常
#    - 检查网络连通性
#    - 查看错误日志
#
# 3. 好友关系异常：
#    - 检查数据库数据一致性
#    - 检查是否有孤立的好友关系
#    - 检查缓存是否过期
#
# 4. 群组功能异常：
#    - 检查群组成员表数据
#    - 检查权限验证逻辑
#    - 查看错误日志

# ============================================================================
# 【与其他服务的关系】
# ============================================================================
# 1. Social API (8881):
#    - HTTP API 服务
#    - 对外提供 RESTful 接口
#    - 调用 Social RPC 服务
#
# 2. Social RPC (10001):
#    - gRPC 服务
#    - 内部服务，不对外暴露
#    - 处理业务逻辑和数据库操作
#
# 3. User RPC (10000):
#    - Social API 需要调用 User RPC 获取用户信息
#    - 例如：显示好友的昵称、头像等
#
# 4. IM API (8882):
#    - 发送消息时需要检查好友关系
#    - 调用 Social API 验证是否为好友

# ============================================================================
# 【端口分配说明】
# ============================================================================
# User API: 8888
# Social API: 8881
# IM API: 8882
# User RPC: 10000
# Social RPC: 10001
# IM RPC: 10002
# IM WS: 10090

# ============================================================================
# 【执行流程总结】
# ============================================================================
# 1. 停止旧容器 → 2. 删除旧容器 → 3. 删除旧镜像
# 4. 拉取新镜像 → 5. 启动新容器
# 6. 服务启动 → 7. 等待客户端请求
