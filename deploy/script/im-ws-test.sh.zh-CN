#!/bin/bash
# ============================================================================
# 脚本名称: im-ws-test.sh
# 脚本用途: 部署 IM WebSocket 测试环境服务
# 所属模块: deploy/script
# ============================================================================

# 【脚本整体说明】
# 这是一个用于部署 IM（即时通讯）WebSocket 服务到测试环境的 Docker 部署脚本。
# WebSocket 服务是即时通讯系统的核心组件，负责：
# 1. 维持客户端的长连接
# 2. 实时推送消息给在线用户
# 3. 处理客户端的心跳和在线状态
# 4. 支持双向实时通信
#
# 【使用场景】
# - 部署即时通讯的 WebSocket 服务
# - 支持 Web、移动端的实时消息推送
# - 维护用户在线状态和长连接管理
#
# 【执行方式】
# 在 deploy/script 目录下执行：
#   bash im-ws-test.sh
# 或者：
#   ./im-ws-test.sh  (需要先 chmod +x im-ws-test.sh)
#
# 【前置要求】
# 1. 已安装 Docker
# 2. 已登录阿里云容器镜像仓库
# 3. 端口 10090 未被占用
# 4. 了解当前服务器的 IP 地址

# ============================================================================
# 配置变量定义
# ============================================================================

# 【变量 1: 镜像仓库地址】
reso_addr='registry.cn-hangzhou.aliyuncs.com/easy-chat/im-ws-dev'
# 说明：
# - registry.cn-hangzhou.aliyuncs.com: 阿里云杭州地域容器镜像服务
# - easy-chat: 命名空间
# - im-ws-dev: WebSocket 服务的开发/测试环境镜像仓库

# 【变量 2: 镜像标签】
tag='latest'
# 说明：
# - latest: 始终拉取最新版本
# - 生产环境建议使用具体版本号

# 【变量 3: POD IP 地址】
pod_ip="192.168.117.24"
# 说明：
# - 当前服务器的 IP 地址
# - 用于服务注册到注册中心（如 etcd）
# - 客户端通过此 IP 建立 WebSocket 连接
# - 重要：部署到不同服务器时，必须修改此 IP
#
# 【为什么 WebSocket 服务需要 POD_IP】
# 1. 服务注册：
#    - 向注册中心注册自己的地址
#    - 其他服务（如 API 服务）需要知道 WebSocket 服务的地址
#
# 2. 负载均衡：
#    - 如果有多个 WebSocket 实例
#    - 客户端连接时需要选择一个实例
#    - 通过注册中心实现负载均衡
#
# 3. 消息路由：
#    - 当用户 A 给用户 B 发消息
#    - 需要找到用户 B 连接的 WebSocket 实例
#    - 通过 POD_IP 定位到具体的服务器
#
# 4. 集群通信：
#    - 多个 WebSocket 实例之间需要通信
#    - 例如：用户 A 在实例 1，用户 B 在实例 2
#    - 实例 1 需要通过 POD_IP 找到实例 2 并转发消息

# 【变量 4: 容器名称】
container_name="easy-chat-im-ws-test"
# 说明：
# - 容器的唯一标识名称
# - 命名规范：项目名-服务名-环境

# ============================================================================
# 步骤 1: 停止运行中的容器
# ============================================================================
docker stop ${container_name}

# 【命令详解】
# 停止名为 easy-chat-im-ws-test 的容器
# - 发送 SIGTERM 信号，让容器优雅关闭
# - WebSocket 服务会：
#   * 停止接受新连接
#   * 通知所有在线用户断开连接
#   * 从注册中心注销自己
#   * 保存必要的状态信息
# - 等待 10 秒后强制终止（SIGKILL）

# ============================================================================
# 步骤 2: 删除已停止的容器
# ============================================================================
docker rm ${container_name}

# 【命令详解】
# 删除已停止的容器实例
# - 释放容器占用的资源
# - 清理旧的容器配置
# - 避免容器名称冲突

# ============================================================================
# 步骤 3: 删除本地镜像
# ============================================================================
docker rmi ${reso_addr}:${tag}

# 【命令详解】
# 删除本地的 im-ws-dev:latest 镜像
# - 确保下一步拉取的是最新版本
# - 释放磁盘空间

# ============================================================================
# 步骤 4: 从远程仓库拉取最新镜像
# ============================================================================
docker pull ${reso_addr}:${tag}

# 【命令详解】
# 从阿里云镜像仓库拉取最新的 im-ws-dev 镜像
# - 下载镜像的所有层
# - 保存到本地 Docker 镜像存储

# ============================================================================
# 步骤 5: 启动新容器
# ============================================================================

# 【注释说明：自定义配置方式】
# 如果需要指定配置文件的
# docker run -p 10001:8080 --network imooc_easy-im -v /easy-im/config/user-rpc:/user/conf/ --name=${container_name} -d ${reso_addr}:${tag}
#
# 【注释命令解析】
# - 这是一个示例，展示如何挂载外部配置文件
# - 当前未使用，因为配置已内置在镜像中

# 【实际执行的启动命令】
docker run -p 10090:10090 -e POD_IP=${pod_ip}  --name=${container_name} -d ${reso_addr}:${tag}

# 【命令详解】
# docker run: 创建并启动一个新容器
#
# 【参数说明】
# -p 10090:10090
#   - 端口映射：宿主机 10090 → 容器 10090
#   - 10090 是 WebSocket 服务监听的端口
#   - 格式：宿主机端口:容器端口
#   - 客户端通过 ws://192.168.117.24:10090 建立连接
#   - 或使用 wss://域名:10090（如果配置了 SSL）
#
# -e POD_IP=${pod_ip}
#   - 设置环境变量 POD_IP=192.168.117.24
#   - 容器内的应用可以通过 os.Getenv("POD_IP") 获取此值
#   - 用途：
#     * 服务注册：向 etcd 注册 ws://192.168.117.24:10090
#     * 消息路由：其他实例通过此 IP 转发消息
#     * 负载均衡：客户端从注册中心获取可用的 WebSocket 地址
#
# --name=${container_name}
#   - 指定容器名称：easy-chat-im-ws-test
#   - 便于后续管理和查看日志
#
# -d
#   - detach 模式（后台运行）
#   - 容器在后台运行，不占用终端
#
# ${reso_addr}:${tag}
#   - 指定要运行的镜像
#   - 完整名称：registry.cn-hangzhou.aliyuncs.com/easy-chat/im-ws-dev:latest

# ============================================================================
# 【WebSocket 服务特点】
# ============================================================================
# 1. 长连接：
#    - 客户端与服务器建立持久连接
#    - 连接保持打开状态，直到主动断开
#    - 避免频繁的连接建立和断开
#
# 2. 双向通信：
#    - 服务器可以主动推送消息给客户端
#    - 客户端也可以发送消息给服务器
#    - 实时性高，延迟低
#
# 3. 心跳机制：
#    - 定期发送心跳包（ping/pong）
#    - 检测连接是否存活
#    - 及时发现断线并清理资源
#
# 4. 在线状态：
#    - 维护用户的在线状态
#    - 用户上线/下线通知
#    - 支持多端登录（Web、移动端）
#
# 5. 消息推送：
#    - 实时推送聊天消息
#    - 推送系统通知
#    - 推送好友请求、群组邀请等
#
# 6. 连接管理：
#    - 管理大量并发连接
#    - 连接池和资源复用
#    - 优雅断开和重连机制

# ============================================================================
# 【WebSocket 连接流程】
# ============================================================================
# 1. 客户端发起连接：
#    - 前端：new WebSocket("ws://192.168.117.24:10090/ws")
#    - 携带认证 token（通常在 URL 参数或 header 中）
#
# 2. 服务器验证：
#    - 验证 token 是否有效
#    - 验证用户是否有权限
#    - 如果验证失败，拒绝连接
#
# 3. 建立连接：
#    - 升级 HTTP 连接为 WebSocket 连接
#    - 保存连接信息（用户 ID、连接 ID、POD_IP）
#    - 更新用户在线状态
#
# 4. 消息收发：
#    - 客户端发送消息 → 服务器处理 → 转发给接收方
#    - 服务器推送消息 → 客户端接收并显示
#
# 5. 心跳保活：
#    - 每隔一段时间（如 30 秒）发送心跳
#    - 如果超时未收到心跳，认为连接断开
#
# 6. 断开连接：
#    - 客户端主动断开
#    - 服务器主动断开（如用户被踢出）
#    - 网络异常导致断开
#    - 清理连接资源，更新在线状态

# ============================================================================
# 【WebSocket 集群架构】
# ============================================================================
# 1. 多实例部署：
#    - 部署多个 WebSocket 实例
#    - 每个实例有不同的 POD_IP
#    - 例如：
#      * 实例 1: 192.168.117.24:10090
#      * 实例 2: 192.168.117.25:10090
#      * 实例 3: 192.168.117.26:10090
#
# 2. 服务注册：
#    - 每个实例启动时注册到 etcd
#    - etcd 中保存所有实例的地址列表
#
# 3. 负载均衡：
#    - 客户端连接时，从 etcd 获取实例列表
#    - 选择一个实例建立连接（随机、轮询、最少连接等）
#    - 或通过 Nginx/HAProxy 做负载均衡
#
# 4. 消息路由：
#    - 用户 A 在实例 1，用户 B 在实例 2
#    - A 发消息给 B：
#      * 实例 1 接收消息
#      * 查询 B 的连接信息（在实例 2）
#      * 通过 RPC 或消息队列转发给实例 2
#      * 实例 2 推送给用户 B
#
# 5. 状态同步：
#    - 使用 Redis 存储用户在线状态
#    - 格式：user:{userId} → {podIp}:{connId}
#    - 所有实例共享在线状态信息

# ============================================================================
# 【部署后的操作建议】
# ============================================================================
# 1. 查看容器状态：
#    docker ps | grep easy-chat-im-ws-test
#
# 2. 查看容器日志：
#    docker logs -f easy-chat-im-ws-test
#    # 检查服务是否成功启动
#    # 检查是否注册到 etcd
#    # 查看连接和消息日志
#
# 3. 进入容器内部：
#    docker exec -it easy-chat-im-ws-test /bin/sh
#
# 4. 检查环境变量：
#    docker exec easy-chat-im-ws-test env | grep POD_IP
#
# 5. 测试 WebSocket 连接：
#    # 使用 wscat 工具测试
#    wscat -c ws://192.168.117.24:10090/ws
#
#    # 或使用浏览器控制台
#    const ws = new WebSocket("ws://192.168.117.24:10090/ws");
#    ws.onopen = () => console.log("连接成功");
#    ws.onmessage = (e) => console.log("收到消息:", e.data);
#    ws.send("Hello");
#
# 6. 检查服务注册：
#    docker exec -it etcd etcdctl get --prefix /easy-chat/im-ws
#
# 7. 查看端口监听：
#    netstat -tlnp | grep 10090
#
# 8. 监控连接数：
#    # 查看当前连接数（需要服务提供监控接口）
#    curl http://192.168.117.24:10090/metrics

# ============================================================================
# 【注意事项】
# ============================================================================
# 1. IP 地址配置：
#    - 必须修改 pod_ip 为实际服务器 IP
#    - 客户端需要能够访问此 IP
#    - 如果是公网部署，使用公网 IP
#
# 2. 端口冲突：
#    - 确保 10090 端口未被占用
#    - 检查命令：netstat -tlnp | grep 10090
#
# 3. 防火墙规则：
#    - 必须开放 10090 端口
#    - 允许客户端访问此端口
#    - 如果有云服务器安全组，也需要配置
#
# 4. 连接数限制：
#    - WebSocket 服务需要维护大量连接
#    - 注意系统的文件描述符限制（ulimit -n）
#    - 建议设置为 65535 或更高
#
# 5. 内存管理：
#    - 每个连接占用一定内存
#    - 监控内存使用情况
#    - 必要时添加内存限制：--memory=2g
#
# 6. 负载均衡：
#    - 单个实例连接数有限
#    - 建议部署多个实例
#    - 使用 Nginx 或 HAProxy 做负载均衡
#
# 7. SSL/TLS：
#    - 生产环境建议使用 wss://（WebSocket Secure）
#    - 需要配置 SSL 证书
#    - 可以在 Nginx 层做 SSL 终止
#
# 8. 跨域问题：
#    - 如果前端和 WebSocket 不在同一域名
#    - 需要配置 CORS
#    - 或使用 Nginx 反向代理

# ============================================================================
# 【故障排查】
# ============================================================================
# 1. 无法建立连接：
#    - 检查服务是否启动：docker ps
#    - 检查端口是否监听：netstat -tlnp | grep 10090
#    - 检查防火墙规则
#    - 检查客户端网络连通性：telnet 192.168.117.24 10090
#
# 2. 连接频繁断开：
#    - 查看日志找出原因
#    - 检查心跳配置
#    - 检查网络稳定性
#    - 检查服务器负载
#
# 3. 消息推送失败：
#    - 检查用户是否在线
#    - 检查消息路由逻辑
#    - 检查 Redis 连接
#    - 查看错误日志
#
# 4. 服务注册失败：
#    - 检查 etcd 是否可访问
#    - 检查 POD_IP 是否正确
#    - 查看服务启动日志

# ============================================================================
# 【与其他服务的区别】
# ============================================================================
# 1. im-api (8882):
#    - HTTP API 服务
#    - 短连接，请求-响应模式
#    - 用于登录、注册、查询等操作
#
# 2. im-rpc (10002):
#    - gRPC 服务
#    - 内部服务调用
#    - 提供业务逻辑接口
#
# 3. im-ws (10090):
#    - WebSocket 服务
#    - 长连接，双向通信
#    - 实时消息推送
#    - 维护在线状态

# ============================================================================
# 【执行流程总结】
# ============================================================================
# 1. 停止旧容器 → 2. 删除旧容器 → 3. 删除旧镜像
# 4. 拉取新镜像 → 5. 启动新容器（带 POD_IP）
# 6. 服务启动 → 7. 注册到 etcd → 8. 等待客户端连接
