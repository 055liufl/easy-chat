#!/bin/bash
# ============================================================================
# 脚本名称: im-api-test.sh
# 脚本用途: 部署 IM API 测试环境服务
# 所属模块: deploy/script
# ============================================================================

# 【脚本整体说明】
# 这是一个用于部署 IM（即时通讯）API 服务到测试环境的 Docker 部署脚本。
# 该脚本会自动完成以下操作：
# 1. 停止并删除旧的容器
# 2. 删除旧的 Docker 镜像
# 3. 从阿里云容器镜像仓库拉取最新镜像
# 4. 启动新的容器实例
#
# 【使用场景】
# - 测试环境部署或更新 IM API 服务
# - 快速回滚到最新版本
# - 自动化部署流程的一部分
#
# 【执行方式】
# 在 deploy/script 目录下执行：
#   bash im-api-test.sh
# 或者：
#   ./im-api-test.sh  (需要先 chmod +x im-api-test.sh)
#
# 【前置要求】
# 1. 已安装 Docker
# 2. 已登录阿里云容器镜像仓库（docker login）
# 3. 具有拉取镜像的权限
# 4. 端口 8882 未被占用

# ============================================================================
# 配置变量定义
# ============================================================================

# 【变量 1: 镜像仓库地址】
reso_addr='registry.cn-hangzhou.aliyuncs.com/easy-chat/im-api-dev'
# 说明：
# - registry.cn-hangzhou.aliyuncs.com: 阿里云杭州地域的容器镜像服务
# - easy-chat: 命名空间（namespace）
# - im-api-dev: 镜像仓库名称（开发/测试环境）
# 注意：生产环境可能使用不同的仓库名（如 im-api-prod）

# 【变量 2: 镜像标签】
tag='latest'
# 说明：
# - latest: 始终拉取最新版本的镜像
# - 也可以指定具体版本号，如：'v1.0.0', '20240315'
# - 生产环境建议使用具体版本号，便于版本管理和回滚

# 【变量 3: 容器名称】
container_name="easy-chat-im-api-test"
# 说明：
# - 容器的唯一标识名称
# - 用于后续的容器管理操作（停止、删除、查看日志等）
# - 命名规范：项目名-服务名-环境

# ============================================================================
# 步骤 1: 停止运行中的容器
# ============================================================================
docker stop ${container_name}

# 【命令详解】
# docker stop: 停止一个或多个运行中的容器
#
# 【执行逻辑】
# 1. 向容器发送 SIGTERM 信号，让容器优雅关闭
# 2. 等待 10 秒（默认超时时间）
# 3. 如果容器仍未停止，发送 SIGKILL 强制终止
#
# 【可能的结果】
# - 成功：输出容器名称
# - 失败：如果容器不存在，会显示错误信息（不影响后续执行）
#
# 【注意事项】
# - 脚本未使用 set -e，即使容器不存在也会继续执行
# - 这是合理的设计，因为首次部署时容器确实不存在

# ============================================================================
# 步骤 2: 删除已停止的容器
# ============================================================================
docker rm ${container_name}

# 【命令详解】
# docker rm: 删除一个或多个已停止的容器
#
# 【执行逻辑】
# 1. 删除容器实例及其相关的文件系统
# 2. 释放容器占用的资源
# 3. 容器必须先停止才能删除（除非使用 -f 强制删除）
#
# 【可能的结果】
# - 成功：输出容器名称
# - 失败：如果容器不存在，会显示错误信息（不影响后续执行）
#
# 【为什么要删除容器】
# - 避免容器名称冲突
# - 清理旧的容器配置
# - 确保使用最新的启动参数

# ============================================================================
# 步骤 3: 删除本地镜像
# ============================================================================
docker rmi ${reso_addr}:${tag}

# 【命令详解】
# docker rmi: 删除一个或多个本地镜像
# rmi = remove image
#
# 【执行逻辑】
# 1. 删除本地存储的 Docker 镜像
# 2. 释放磁盘空间
# 3. 确保下一步拉取的是最新镜像
#
# 【完整镜像名称】
# registry.cn-hangzhou.aliyuncs.com/easy-chat/im-api-dev:latest
#
# 【可能的结果】
# - 成功：输出镜像 ID
# - 失败：如果镜像不存在，会显示错误信息（不影响后续执行）
#
# 【为什么要删除镜像】
# - 因为使用 latest 标签，本地可能缓存了旧版本
# - 删除后重新拉取，确保获取最新版本
# - 如果使用具体版本号标签，这一步可以省略

# ============================================================================
# 步骤 4: 从远程仓库拉取最新镜像
# ============================================================================
docker pull ${reso_addr}:${tag}

# 【命令详解】
# docker pull: 从镜像仓库拉取镜像到本地
#
# 【执行逻辑】
# 1. 连接到阿里云容器镜像仓库
# 2. 检查镜像的 latest 标签对应的版本
# 3. 下载镜像的所有层（layers）
# 4. 保存到本地 Docker 镜像存储
#
# 【输出信息】
# - 显示下载进度
# - 显示镜像的 digest（SHA256 哈希值）
# - 显示镜像大小
#
# 【可能的失败原因】
# - 网络连接问题
# - 未登录镜像仓库（需要 docker login）
# - 镜像不存在或无权限访问
# - 磁盘空间不足
#
# 【注意事项】
# - 拉取速度取决于网络带宽和镜像大小
# - 阿里云镜像仓库在国内访问速度较快

# ============================================================================
# 步骤 5: 启动新容器
# ============================================================================

# 【注释说明：自定义配置方式】
# 如果需要指定配置文件的
# docker run -p 10001:8080 --network imooc_easy-im -v /easy-im/config/user-rpc:/user/conf/ --name=${container_name} -d ${reso_addr}:${tag}
#
# 【注释命令解析】
# -p 10001:8080
#   - 端口映射：宿主机 10001 → 容器 8080
# --network imooc_easy-im
#   - 指定 Docker 网络，用于容器间通信
# -v /easy-im/config/user-rpc:/user/conf/
#   - 挂载配置文件目录
#   - 宿主机路径:/easy-im/config/user-rpc
#   - 容器内路径:/user/conf/
#   - 用于外部管理配置文件，无需重新构建镜像
#
# 【为什么注释掉】
# - 当前使用镜像内置的配置文件
# - 简化部署流程
# - 如需自定义配置，可取消注释并修改路径

# 【实际执行的启动命令】
docker run -p 8882:8882  --name=${container_name} -d ${reso_addr}:${tag}

# 【命令详解】
# docker run: 创建并启动一个新容器
#
# 【参数说明】
# -p 8882:8882
#   - 端口映射（port mapping）
#   - 格式：宿主机端口:容器端口
#   - 8882(左): 宿主机端口，外部访问使用此端口
#   - 8882(右): 容器内部端口，应用监听的端口
#   - 作用：将容器的 8882 端口暴露到宿主机
#   - 访问方式：http://宿主机IP:8882
#
# --name=${container_name}
#   - 指定容器名称为 easy-chat-im-api-test
#   - 便于后续管理（查看日志、停止、重启等）
#   - 容器名称在同一主机上必须唯一
#
# -d
#   - detach 模式（后台运行）
#   - 容器在后台运行，不占用当前终端
#   - 返回容器 ID
#   - 如需查看日志：docker logs ${container_name}
#
# ${reso_addr}:${tag}
#   - 指定要运行的镜像
#   - 完整名称：registry.cn-hangzhou.aliyuncs.com/easy-chat/im-api-dev:latest
#
# 【未使用的常用参数】
# --restart=always: 自动重启策略（建议生产环境添加）
# -e KEY=VALUE: 环境变量（如数据库连接信息）
# --network: Docker 网络（用于容器间通信）
# -v: 数据卷挂载（持久化数据）
# --memory: 内存限制
# --cpus: CPU 限制
#
# 【执行结果】
# - 成功：输出容器 ID（64 位十六进制字符串）
# - 失败：显示错误信息（如端口被占用、镜像不存在等）

# ============================================================================
# 【部署后的操作建议】
# ============================================================================
# 1. 查看容器状态：
#    docker ps | grep easy-chat-im-api-test
#
# 2. 查看容器日志：
#    docker logs -f easy-chat-im-api-test
#    (-f 参数表示持续输出日志)
#
# 3. 进入容器内部：
#    docker exec -it easy-chat-im-api-test /bin/sh
#
# 4. 查看容器详细信息：
#    docker inspect easy-chat-im-api-test
#
# 5. 停止容器：
#    docker stop easy-chat-im-api-test
#
# 6. 重启容器：
#    docker restart easy-chat-im-api-test
#
# 7. 测试服务是否正常：
#    curl http://localhost:8882/health
#    或访问具体的 API 接口

# ============================================================================
# 【注意事项】
# ============================================================================
# 1. 端口冲突：
#    - 确保宿主机 8882 端口未被占用
#    - 可使用 netstat -tlnp | grep 8882 检查
#
# 2. 镜像权限：
#    - 首次使用需要 docker login 登录阿里云镜像仓库
#    - 登录命令：docker login --username=xxx registry.cn-hangzhou.aliyuncs.com
#
# 3. 网络访问：
#    - 如果容器需要访问其他服务（数据库、Redis、其他微服务）
#    - 建议使用 --network 参数指定 Docker 网络
#
# 4. 数据持久化：
#    - 当前配置未挂载数据卷
#    - 容器删除后数据会丢失
#    - 如需持久化，使用 -v 参数挂载数据目录
#
# 5. 资源限制：
#    - 当前未设置资源限制
#    - 生产环境建议添加 --memory 和 --cpus 限制
#
# 6. 日志管理：
#    - Docker 默认使用 json-file 日志驱动
#    - 日志会占用磁盘空间，建议配置日志轮转
#    - 可使用 --log-opt max-size=10m --log-opt max-file=3
#
# 7. 健康检查：
#    - 建议在 Dockerfile 中添加 HEALTHCHECK 指令
#    - 或使用 --health-cmd 参数
#
# 8. 环境区分：
#    - 当前为测试环境（im-api-dev）
#    - 生产环境应使用不同的镜像仓库和标签

# ============================================================================
# 【故障排查】
# ============================================================================
# 1. 容器启动失败：
#    - 查看日志：docker logs easy-chat-im-api-test
#    - 检查端口占用：netstat -tlnp | grep 8882
#    - 检查镜像是否正确：docker images | grep im-api-dev
#
# 2. 无法拉取镜像：
#    - 检查网络连接
#    - 检查是否已登录：docker login
#    - 检查镜像地址是否正确
#
# 3. 服务无法访问：
#    - 检查容器是否运行：docker ps
#    - 检查端口映射：docker port easy-chat-im-api-test
#    - 检查防火墙规则
#    - 检查服务是否正常启动（查看日志）
#
# 4. 容器频繁重启：
#    - 查看日志找出原因
#    - 检查配置文件是否正确
#    - 检查依赖服务是否可用（数据库、Redis 等）

# ============================================================================
# 【执行流程总结】
# ============================================================================
# 1. 停止旧容器 → 2. 删除旧容器 → 3. 删除旧镜像
# 4. 拉取新镜像 → 5. 启动新容器
# 整个过程实现了服务的完全更新和重新部署
