#!/bin/bash
# ============================================================================
# 脚本名称: im-rpc-test.sh
# 脚本用途: 部署 IM RPC 测试环境服务
# 所属模块: deploy/script
# ============================================================================

# 【脚本整体说明】
# 这是一个用于部署 IM（即时通讯）RPC 服务到测试环境的 Docker 部署脚本。
# RPC（Remote Procedure Call）服务是微服务架构中的内部服务，提供 gRPC 接口供其他服务调用。
# 该脚本会自动完成以下操作：
# 1. 停止并删除旧的容器
# 2. 删除旧的 Docker 镜像
# 3. 从阿里云容器镜像仓库拉取最新镜像
# 4. 启动新的容器实例（带 POD_IP 环境变量）
#
# 【使用场景】
# - 测试环境部署或更新 IM RPC 服务
# - 微服务架构中的内部服务部署
# - 提供 gRPC 接口供 API 层或其他 RPC 服务调用
#
# 【执行方式】
# 在 deploy/script 目录下执行：
#   bash im-rpc-test.sh
# 或者：
#   ./im-rpc-test.sh  (需要先 chmod +x im-rpc-test.sh)
#
# 【前置要求】
# 1. 已安装 Docker
# 2. 已登录阿里云容器镜像仓库
# 3. 端口 10002 未被占用
# 4. 了解当前服务器的 IP 地址（用于服务注册）

# ============================================================================
# 配置变量定义
# ============================================================================

# 【变量 1: 镜像仓库地址】
reso_addr='registry.cn-hangzhou.aliyuncs.com/easy-chat/im-rpc-dev'
# 说明：
# - registry.cn-hangzhou.aliyuncs.com: 阿里云杭州地域容器镜像服务
# - easy-chat: 命名空间
# - im-rpc-dev: RPC 服务的开发/测试环境镜像仓库

# 【变量 2: 镜像标签】
tag='latest'
# 说明：
# - latest: 始终拉取最新版本
# - 生产环境建议使用具体版本号

# 【变量 3: POD IP 地址】
pod_ip="192.168.117.24"
# 说明：
# - 当前服务器的 IP 地址
# - 用于服务注册到注册中心（如 etcd、consul、nacos）
# - 其他服务通过此 IP 访问当前 RPC 服务
# - 重要：部署到不同服务器时，必须修改此 IP 为实际服务器 IP
#
# 【如何获取服务器 IP】
# - Linux: ip addr show 或 ifconfig
# - 选择正确的网卡（通常是 eth0 或 ens33）
# - 使用内网 IP，不要使用 127.0.0.1
#
# 【为什么需要 POD_IP】
# - 在 Kubernetes 环境中，POD_IP 是 Pod 的 IP 地址
# - 在非 K8s 环境中，使用服务器的实际 IP
# - 服务注册时需要告诉注册中心自己的访问地址
# - 其他服务通过注册中心发现并调用此服务

# 【变量 4: 容器名称】
container_name="easy-chat-im-rpc-test"
# 说明：
# - 容器的唯一标识名称
# - 命名规范：项目名-服务名-环境

# ============================================================================
# 步骤 1: 停止运行中的容器
# ============================================================================
docker stop ${container_name}

# 【命令详解】
# 停止名为 easy-chat-im-rpc-test 的容器
# - 发送 SIGTERM 信号，让容器优雅关闭
# - 等待 10 秒后强制终止（SIGKILL）
# - 如果容器不存在，会显示错误但不影响后续执行

# ============================================================================
# 步骤 2: 删除已停止的容器
# ============================================================================
docker rm ${container_name}

# 【命令详解】
# 删除已停止的容器实例
# - 释放容器占用的资源
# - 避免容器名称冲突
# - 清理旧的容器配置

# ============================================================================
# 步骤 3: 删除本地镜像
# ============================================================================
docker rmi ${reso_addr}:${tag}

# 【命令详解】
# 删除本地的 im-rpc-dev:latest 镜像
# - 确保下一步拉取的是最新版本
# - 释放磁盘空间
# - 避免使用缓存的旧镜像

# ============================================================================
# 步骤 4: 从远程仓库拉取最新镜像
# ============================================================================
docker pull ${reso_addr}:${tag}

# 【命令详解】
# 从阿里云镜像仓库拉取最新的 im-rpc-dev 镜像
# - 下载镜像的所有层
# - 保存到本地 Docker 镜像存储
# - 显示下载进度和镜像信息

# ============================================================================
# 步骤 5: 启动新容器
# ============================================================================

# 【注释说明：自定义配置方式】
# 如果需要指定配置文件的
# docker run -p 10001:8080 --network imooc_easy-im -v /easy-im/config/user-rpc:/user/conf/ --name=${container_name} -d ${reso_addr}:${tag}
#
# 【注释命令解析】
# - 这是一个示例，展示如何挂载外部配置文件
# - 当前未使用，因为配置已内置在镜像中
# - 如需自定义配置，可取消注释并修改参数

# 【实际执行的启动命令】
docker run -p 10002:10002 -e POD_IP=${pod_ip}  --name=${container_name} -d ${reso_addr}:${tag}

# 【命令详解】
# docker run: 创建并启动一个新容器
#
# 【参数说明】
# -p 10002:10002
#   - 端口映射：宿主机 10002 → 容器 10002
#   - 10002 是 gRPC 服务监听的端口
#   - 格式：宿主机端口:容器端口
#   - 作用：将容器的 gRPC 端口暴露到宿主机
#   - 其他服务通过 宿主机IP:10002 访问此 RPC 服务
#
# -e POD_IP=${pod_ip}
#   - 设置环境变量 POD_IP=192.168.117.24
#   - -e 或 --env: 设置环境变量
#   - 容器内的应用可以通过 os.Getenv("POD_IP") 获取此值
#   - 用途：
#     * 服务注册时使用此 IP
#     * 告诉注册中心自己的访问地址
#     * 其他服务通过注册中心发现并调用
#   - 示例：注册到 etcd 时，地址为 192.168.117.24:10002
#
# --name=${container_name}
#   - 指定容器名称：easy-chat-im-rpc-test
#   - 便于后续管理和查看日志
#
# -d
#   - detach 模式（后台运行）
#   - 容器在后台运行，不占用终端
#   - 返回容器 ID
#
# ${reso_addr}:${tag}
#   - 指定要运行的镜像
#   - 完整名称：registry.cn-hangzhou.aliyuncs.com/easy-chat/im-rpc-dev:latest

# ============================================================================
# 【RPC 服务特点】
# ============================================================================
# 1. 内部服务：
#    - RPC 服务通常不直接对外暴露
#    - 仅供内部微服务调用
#    - 使用 gRPC 协议（基于 HTTP/2）
#
# 2. 服务注册：
#    - 启动时向注册中心注册自己的地址
#    - 注册信息：服务名、IP、端口、健康状态等
#    - 常用注册中心：etcd、consul、nacos
#
# 3. 服务发现：
#    - 其他服务通过注册中心发现 RPC 服务
#    - 支持负载均衡（多个实例）
#    - 支持健康检查和自动摘除故障节点
#
# 4. 通信协议：
#    - 使用 gRPC（Protocol Buffers）
#    - 比 HTTP/JSON 更高效
#    - 支持流式传输
#    - 强类型接口定义

# ============================================================================
# 【POD_IP 的重要性】
# ============================================================================
# 1. 服务注册：
#    - 服务启动时，会将 POD_IP:10002 注册到 etcd
#    - 例如：etcd key: /easy-chat/im-rpc/192.168.117.24:10002
#
# 2. 服务发现：
#    - 其他服务从 etcd 获取 im-rpc 的地址列表
#    - 选择一个地址进行 gRPC 调用
#
# 3. 负载均衡：
#    - 如果有多个 im-rpc 实例，每个实例注册不同的 IP:Port
#    - 客户端可以实现负载均衡（轮询、随机、权重等）
#
# 4. 健康检查：
#    - 注册中心定期检查服务健康状态
#    - 如果服务不可用，自动从注册中心移除
#
# 5. 注意事项：
#    - 不能使用 127.0.0.1（其他服务无法访问）
#    - 必须使用服务器的实际 IP
#    - 如果 IP 错误，其他服务无法调用此 RPC 服务

# ============================================================================
# 【部署后的操作建议】
# ============================================================================
# 1. 查看容器状态：
#    docker ps | grep easy-chat-im-rpc-test
#
# 2. 查看容器日志：
#    docker logs -f easy-chat-im-rpc-test
#    # 检查服务是否成功注册到 etcd
#    # 检查 gRPC 服务是否正常启动
#
# 3. 进入容器内部：
#    docker exec -it easy-chat-im-rpc-test /bin/sh
#
# 4. 检查环境变量：
#    docker exec easy-chat-im-rpc-test env | grep POD_IP
#    # 应该输出：POD_IP=192.168.117.24
#
# 5. 测试 gRPC 服务：
#    # 使用 grpcurl 工具测试
#    grpcurl -plaintext 192.168.117.24:10002 list
#
# 6. 检查服务注册：
#    # 连接到 etcd 查看注册信息
#    docker exec -it etcd etcdctl get --prefix /easy-chat/im-rpc
#
# 7. 查看端口监听：
#    netstat -tlnp | grep 10002
#    # 应该看到 10002 端口在监听

# ============================================================================
# 【注意事项】
# ============================================================================
# 1. IP 地址配置：
#    - 必须修改 pod_ip 为实际服务器 IP
#    - 不能使用 127.0.0.1 或 localhost
#    - 使用内网 IP，确保其他服务可以访问
#
# 2. 端口冲突：
#    - 确保 10002 端口未被占用
#    - 检查命令：netstat -tlnp | grep 10002
#
# 3. 服务依赖：
#    - 确保注册中心（etcd）已启动
#    - 确保数据库、Redis 等依赖服务可访问
#    - 检查网络连通性
#
# 4. 防火墙规则：
#    - 如果有防火墙，需要开放 10002 端口
#    - 允许其他服务器访问此端口
#
# 5. 容器网络：
#    - 当前使用默认网络（bridge）
#    - 如需容器间通信，建议使用自定义网络
#    - 例如：--network easy-chat-network
#
# 6. 资源限制：
#    - 生产环境建议添加资源限制
#    - 例如：--memory=512m --cpus=1
#
# 7. 日志管理：
#    - 配置日志轮转，避免日志文件过大
#    - 例如：--log-opt max-size=10m --log-opt max-file=3
#
# 8. 健康检查：
#    - 建议添加健康检查
#    - 例如：--health-cmd="grpc_health_probe -addr=:10002"

# ============================================================================
# 【故障排查】
# ============================================================================
# 1. 服务无法启动：
#    - 查看日志：docker logs easy-chat-im-rpc-test
#    - 检查端口占用
#    - 检查依赖服务是否可用
#
# 2. 其他服务无法调用：
#    - 检查 POD_IP 是否正确
#    - 检查服务是否注册到 etcd
#    - 检查网络连通性：ping 192.168.117.24
#    - 检查端口是否开放：telnet 192.168.117.24 10002
#
# 3. 服务注册失败：
#    - 检查 etcd 是否可访问
#    - 查看日志中的错误信息
#    - 检查 POD_IP 环境变量是否正确传入
#
# 4. gRPC 调用超时：
#    - 检查服务是否正常运行
#    - 检查网络延迟
#    - 检查服务负载是否过高

# ============================================================================
# 【与 im-api-test.sh 的区别】
# ============================================================================
# 1. 服务类型：
#    - im-api: HTTP API 服务（对外）
#    - im-rpc: gRPC RPC 服务（内部）
#
# 2. 端口：
#    - im-api: 8882（HTTP）
#    - im-rpc: 10002（gRPC）
#
# 3. 环境变量：
#    - im-api: 无需 POD_IP
#    - im-rpc: 需要 POD_IP 用于服务注册
#
# 4. 访问方式：
#    - im-api: 浏览器、curl、Postman
#    - im-rpc: gRPC 客户端、grpcurl

# ============================================================================
# 【执行流程总结】
# ============================================================================
# 1. 停止旧容器 → 2. 删除旧容器 → 3. 删除旧镜像
# 4. 拉取新镜像 → 5. 启动新容器（带 POD_IP 环境变量）
# 6. 服务启动 → 7. 注册到 etcd → 8. 等待其他服务调用
