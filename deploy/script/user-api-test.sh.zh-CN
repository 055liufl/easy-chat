#!/bin/bash
# ============================================================================
# 脚本名称: user-api-test.sh
# 脚本用途: 部署 User API 测试环境服务
# 所属模块: deploy/script
# ============================================================================

# 【脚本整体说明】
# 这是一个用于部署 User（用户）API 服务到测试环境的 Docker 部署脚本。
# User API 服务提供用户相关的 HTTP 接口，包括：
# 1. 用户注册和登录
# 2. 用户信息查询和更新
# 3. 用户资料管理
# 4. 用户认证和授权
#
# 【使用场景】
# - 测试环境部署或更新 User API 服务
# - 提供用户管理相关的 RESTful API
# - 前端或移动端调用的用户服务接口
#
# 【执行方式】
# 在 deploy/script 目录下执行：
#   bash user-api-test.sh
# 或者：
#   ./user-api-test.sh  (需要先 chmod +x user-api-test.sh)
#
# 【前置要求】
# 1. 已安装 Docker
# 2. 已登录阿里云容器镜像仓库
# 3. 端口 8888 未被占用

# ============================================================================
# 配置变量定义
# ============================================================================

# 【变量 1: 镜像仓库地址】
reso_addr='registry.cn-hangzhou.aliyuncs.com/easy-chat/user-api-dev'
# 说明：
# - registry.cn-hangzhou.aliyuncs.com: 阿里云杭州地域容器镜像服务
# - easy-chat: 命名空间
# - user-api-dev: User API 服务的开发/测试环境镜像仓库

# 【变量 2: 镜像标签】
tag='latest'
# 说明：
# - latest: 始终拉取最新版本
# - 生产环境建议使用具体版本号

# 【变量 3: 容器名称】
container_name="easy-chat-user-api-test"
# 说明：
# - 容器的唯一标识名称
# - 命名规范：项目名-服务名-环境

# ============================================================================
# 步骤 1: 停止运行中的容器
# ============================================================================
docker stop ${container_name}

# 【命令详解】
# 停止名为 easy-chat-user-api-test 的容器
# - 发送 SIGTERM 信号，让容器优雅关闭
# - 如果容器不存在，会显示错误但不影响后续执行

# ============================================================================
# 步骤 2: 删除已停止的容器
# ============================================================================
docker rm ${container_name}

# 【命令详解】
# 删除已停止的容器实例
# - 释放容器占用的资源
# - 避免容器名称冲突

# ============================================================================
# 步骤 3: 删除本地镜像
# ============================================================================
docker rmi ${reso_addr}:${tag}

# 【命令详解】
# 删除本地的 user-api-dev:latest 镜像
# - 确保下一步拉取的是最新版本
# - 释放磁盘空间

# ============================================================================
# 步骤 4: 从远程仓库拉取最新镜像
# ============================================================================
docker pull ${reso_addr}:${tag}

# 【命令详解】
# 从阿里云镜像仓库拉取最新的 user-api-dev 镜像
# - 下载镜像的所有层
# - 保存到本地 Docker 镜像存储

# ============================================================================
# 步骤 5: 启动新容器
# ============================================================================

# 【注释说明：自定义配置方式】
# 如果需要指定配置文件的
# docker run -p 10001:8080 --network imooc_easy-im -v /easy-im/config/user-rpc:/user/conf/ --name=${container_name} -d ${reso_addr}:${tag}

# 【实际执行的启动命令】
docker run -p 8888:8888  --name=${container_name} -d ${reso_addr}:${tag}

# 【命令详解】
# docker run: 创建并启动一个新容器
#
# 【参数说明】
# -p 8888:8888
#   - 端口映射：宿主机 8888 → 容器 8888
#   - 8888 是 User API 服务监听的 HTTP 端口
#   - 客户端通过 http://服务器IP:8888 访问 API
#   - 例如：http://192.168.117.24:8888/api/user/login
#
# --name=${container_name}
#   - 指定容器名称：easy-chat-user-api-test
#   - 便于后续管理和查看日志
#
# -d
#   - detach 模式（后台运行）
#   - 容器在后台运行，不占用终端
#
# ${reso_addr}:${tag}
#   - 指定要运行的镜像
#   - 完整名称：registry.cn-hangzhou.aliyuncs.com/easy-chat/user-api-dev:latest

# ============================================================================
# 【User API 服务功能】
# ============================================================================
# 1. 用户注册：
#    - POST /api/user/register
#    - 参数：用户名、密码、邮箱、手机号等
#    - 返回：用户 ID、token
#
# 2. 用户登录：
#    - POST /api/user/login
#    - 参数：用户名/邮箱/手机号、密码
#    - 返回：token、用户信息
#
# 3. 获取用户信息：
#    - GET /api/user/info
#    - 参数：token（header 或 query）
#    - 返回：用户详细信息
#
# 4. 更新用户信息：
#    - PUT /api/user/info
#    - 参数：昵称、头像、个性签名等
#    - 返回：更新结果
#
# 5. 修改密码：
#    - POST /api/user/password
#    - 参数：旧密码、新密码
#    - 返回：修改结果
#
# 6. 用户搜索：
#    - GET /api/user/search
#    - 参数：关键词
#    - 返回：用户列表
#
# 7. 用户注销：
#    - POST /api/user/logout
#    - 参数：token
#    - 返回：注销结果

# ============================================================================
# 【API 服务架构】
# ============================================================================
# 1. 请求流程：
#    客户端 → Nginx（可选）→ User API → User RPC → 数据库
#
# 2. 分层架构：
#    - Handler 层：处理 HTTP 请求，参数验证
#    - Logic 层：业务逻辑处理
#    - RPC 层：调用 User RPC 服务
#    - Model 层：数据库操作（在 RPC 服务中）
#
# 3. 认证授权：
#    - 使用 JWT token 进行认证
#    - 中间件验证 token 有效性
#    - 提取用户信息并传递给业务层
#
# 4. 错误处理：
#    - 统一的错误码和错误信息
#    - 返回标准的 JSON 格式
#    - 例如：{"code": 200, "msg": "success", "data": {...}}

# ============================================================================
# 【部署后的操作建议】
# ============================================================================
# 1. 查看容器状态：
#    docker ps | grep easy-chat-user-api-test
#
# 2. 查看容器日志：
#    docker logs -f easy-chat-user-api-test
#
# 3. 测试 API 接口：
#    # 健康检查
#    curl http://localhost:8888/health
#
#    # 用户注册
#    curl -X POST http://localhost:8888/api/user/register \
#      -H "Content-Type: application/json" \
#      -d '{"username":"test","password":"123456","email":"test@example.com"}'
#
#    # 用户登录
#    curl -X POST http://localhost:8888/api/user/login \
#      -H "Content-Type: application/json" \
#      -d '{"username":"test","password":"123456"}'
#
# 4. 查看 API 文档：
#    # 如果集成了 Swagger
#    http://localhost:8888/swagger/index.html
#
# 5. 进入容器内部：
#    docker exec -it easy-chat-user-api-test /bin/sh

# ============================================================================
# 【注意事项】
# ============================================================================
# 1. 端口冲突：
#    - 确保 8888 端口未被占用
#    - 检查命令：netstat -tlnp | grep 8888
#
# 2. 依赖服务：
#    - 确保 User RPC 服务已启动
#    - 确保数据库、Redis 等依赖服务可访问
#    - 检查服务注册中心（etcd）是否正常
#
# 3. 跨域配置：
#    - 如果前端和 API 不在同一域名
#    - 需要配置 CORS（跨域资源共享）
#    - 在代码中添加 CORS 中间件
#
# 4. 日志管理：
#    - 配置日志级别（开发环境：debug，生产环境：info）
#    - 配置日志轮转，避免日志文件过大
#
# 5. 性能优化：
#    - 使用连接池（数据库、Redis、RPC）
#    - 添加缓存（Redis）
#    - 使用 CDN 加速静态资源
#
# 6. 安全性：
#    - 使用 HTTPS（生产环境）
#    - 密码加密存储（bcrypt）
#    - 防止 SQL 注入、XSS 攻击
#    - 限流和防刷（rate limiting）

# ============================================================================
# 【故障排查】
# ============================================================================
# 1. 服务无法启动：
#    - 查看日志：docker logs easy-chat-user-api-test
#    - 检查端口占用
#    - 检查配置文件是否正确
#
# 2. API 调用失败：
#    - 检查 User RPC 服务是否正常
#    - 检查网络连通性
#    - 查看错误日志
#
# 3. 认证失败：
#    - 检查 token 是否有效
#    - 检查 token 是否过期
#    - 检查 JWT 密钥配置
#
# 4. 数据库连接失败：
#    - 检查数据库是否启动
#    - 检查数据库连接配置
#    - 检查网络连通性

# ============================================================================
# 【与其他服务的关系】
# ============================================================================
# 1. User API (8888):
#    - HTTP API 服务
#    - 对外提供 RESTful 接口
#    - 调用 User RPC 服务
#
# 2. User RPC (10000):
#    - gRPC 服务
#    - 内部服务，不对外暴露
#    - 处理业务逻辑和数据库操作
#
# 3. IM API (8882):
#    - 即时通讯 API 服务
#    - 可能需要调用 User API 获取用户信息
#
# 4. Social API (8881):
#    - 社交功能 API 服务
#    - 可能需要调用 User API 获取用户信息

# ============================================================================
# 【执行流程总结】
# ============================================================================
# 1. 停止旧容器 → 2. 删除旧容器 → 3. 删除旧镜像
# 4. 拉取新镜像 → 5. 启动新容器
# 6. 服务启动 → 7. 等待客户端请求
