#!/bin/bash
# ============================================================================
# 脚本名称: release-test.sh
# 脚本用途: 一键部署所有测试环境服务
# 所属模块: deploy/script
# ============================================================================

# 【脚本整体说明】
# 这是一个用于一键部署整个 easy-chat 项目所有服务到测试环境的批量部署脚本。
# 该脚本会按照正确的顺序依次执行所有服务的部署脚本，包括：
# 1. RPC 服务（内部服务，提供 gRPC 接口）
# 2. API 服务（对外服务，提供 HTTP 接口）
# 3. WebSocket 服务（实时通信服务）
# 4. Task MQ 服务（异步任务处理服务）
#
# 【使用场景】
# - 测试环境的初始化部署
# - 测试环境的整体更新
# - 快速部署所有服务
# - 自动化部署流程
# - CI/CD 持续集成和持续部署
#
# 【执行方式】
# 在 deploy/script 目录下执行：
#   bash release-test.sh
# 或者：
#   ./release-test.sh  (需要先 chmod +x release-test.sh)
#
# 【前置要求】
# 1. 已安装 Docker
# 2. 已登录阿里云容器镜像仓库
# 3. 所有需要的端口未被占用
# 4. 依赖服务已启动（MySQL、Redis、etcd 等）
# 5. 所有单独的部署脚本文件存在且可执行

# ============================================================================
# 配置变量定义：需要启动的服务脚本列表
# ============================================================================

need_start_server_shell=(
  # rpc
  im-ws-test.sh
  im-rpc-test.sh
  user-rpc-test.sh
  social-rpc-test.sh

  # api
  im-api-test.sh
  user-api-test.sh
  social-api-test.sh

  # task
  task-mq-test.sh
)

# 【数组说明】
# need_start_server_shell: 需要启动的服务脚本数组
# - 数组元素：各个服务的部署脚本文件名
# - 执行顺序：按照数组顺序依次执行
#
# 【服务分类】
# 1. RPC 服务（4 个）：
#    - im-ws-test.sh: IM WebSocket 服务（端口 10090）
#    - im-rpc-test.sh: IM RPC 服务（端口 10002）
#    - user-rpc-test.sh: User RPC 服务（端口 10000）
#    - social-rpc-test.sh: Social RPC 服务（端口 10001）
#
# 2. API 服务（3 个）：
#    - im-api-test.sh: IM API 服务（端口 8882）
#    - user-api-test.sh: User API 服务（端口 8888）
#    - social-api-test.sh: Social API 服务（端口 8881）
#
# 3. Task 服务（1 个）：
#    - task-mq-test.sh: Task MQ 服务（无对外端口）
#
# 【部署顺序说明】
# 1. 先部署 RPC 服务：
#    - RPC 服务是内部服务，API 服务依赖 RPC 服务
#    - 必须先启动 RPC 服务，API 服务才能正常调用
#
# 2. 再部署 API 服务：
#    - API 服务对外提供 HTTP 接口
#    - 依赖 RPC 服务提供业务逻辑
#
# 3. 最后部署 Task 服务：
#    - Task MQ 服务独立运行
#    - 消费消息队列中的任务
#    - 不影响其他服务启动
#
# 【为什么 WebSocket 服务在 RPC 分类中】
# - 虽然 WebSocket 服务对外提供服务
# - 但它也需要注册到服务中心（etcd）
# - 其他服务可能需要通过 RPC 调用 WebSocket 服务
# - 例如：API 服务推送消息时，需要找到用户连接的 WebSocket 实例

# ============================================================================
# 主循环：遍历数组，依次执行每个部署脚本
# ============================================================================

for i in ${need_start_server_shell[*]} ; do
    chmod +x $i
    ./$i
done

# 【循环详解】
# for i in ${need_start_server_shell[*]} ; do
#   - 遍历 need_start_server_shell 数组中的每个元素
#   - ${need_start_server_shell[*]}: 展开数组所有元素
#   - i: 当前循环的脚本文件名
#
# 【命令 1: chmod +x $i】
# - chmod: 修改文件权限
# - +x: 添加可执行权限
# - $i: 当前脚本文件名
# - 作用：确保脚本文件可执行
# - 说明：即使脚本已经有执行权限，重复执行也不会出错
#
# 【命令 2: ./$i】
# - ./: 当前目录
# - $i: 脚本文件名
# - 作用：执行当前脚本
# - 说明：
#   * 脚本会在当前 shell 的子进程中执行
#   * 脚本执行完成后，继续执行下一个脚本
#   * 如果脚本执行失败，不会中断循环（因为没有 set -e）
#
# 【执行流程】
# 1. 第一次循环：i = "im-ws-test.sh"
#    - chmod +x im-ws-test.sh
#    - ./im-ws-test.sh
#    - 等待脚本执行完成
#
# 2. 第二次循环：i = "im-rpc-test.sh"
#    - chmod +x im-rpc-test.sh
#    - ./im-rpc-test.sh
#    - 等待脚本执行完成
#
# 3. 依此类推，直到所有脚本执行完成

# ============================================================================
# 部署完成后：查看所有容器状态
# ============================================================================

docker ps

# 【命令详解】
# docker ps: 列出所有正在运行的容器
#
# 【输出信息】
# - CONTAINER ID: 容器 ID（短格式）
# - IMAGE: 使用的镜像
# - COMMAND: 容器启动命令
# - CREATED: 容器创建时间
# - STATUS: 容器状态（Up 表示运行中）
# - PORTS: 端口映射
# - NAMES: 容器名称
#
# 【作用】
# - 检查所有服务是否成功启动
# - 查看容器运行状态
# - 确认端口映射是否正确
#
# 【预期输出】
# 应该看到 8 个容器正在运行：
# - easy-chat-im-ws-test
# - easy-chat-im-rpc-test
# - easy-chat-user-rpc-test
# - easy-chat-social-rpc-test
# - easy-chat-im-api-test
# - easy-chat-user-api-test
# - easy-chat-social-api-test
# - easy-chat-task-mq-test

# ============================================================================
# 部署完成后：查看 etcd 中的服务注册信息
# ============================================================================

docker exec -it etcd etcdctl get --prefix ""

# 【命令详解】
# docker exec: 在运行中的容器内执行命令
# -it: 交互式终端（-i: 交互模式，-t: 分配伪终端）
# etcd: 容器名称（假设 etcd 容器名为 etcd）
# etcdctl: etcd 的命令行工具
# get: 获取键值
# --prefix "": 获取所有键值（空前缀表示匹配所有）
#
# 【作用】
# - 查看所有服务的注册信息
# - 验证 RPC 服务是否成功注册到 etcd
# - 检查服务地址是否正确
#
# 【预期输出】
# 应该看到以下服务的注册信息：
# - /easy-chat/user-rpc/192.168.117.24:10000
# - /easy-chat/social-rpc/192.168.117.24:10001
# - /easy-chat/im-rpc/192.168.117.24:10002
# - /easy-chat/im-ws/192.168.117.24:10090
#
# 【注意】
# - 如果 etcd 容器名称不是 "etcd"，需要修改命令
# - 如果 etcd 未启动，此命令会失败
# - API 服务通常不注册到 etcd（因为它们不需要被其他服务发现）

# ============================================================================
# 【部署后的验证步骤】
# ============================================================================
# 1. 检查容器状态：
#    docker ps
#    # 确认所有 8 个容器都在运行
#
# 2. 检查服务注册：
#    docker exec -it etcd etcdctl get --prefix ""
#    # 确认 RPC 服务已注册到 etcd
#
# 3. 检查容器日志：
#    docker logs easy-chat-user-api-test
#    docker logs easy-chat-user-rpc-test
#    # 查看是否有错误信息
#
# 4. 测试 API 接口：
#    curl http://localhost:8888/health  # User API
#    curl http://localhost:8881/health  # Social API
#    curl http://localhost:8882/health  # IM API
#
# 5. 测试 WebSocket 连接：
#    wscat -c ws://localhost:10090/ws
#
# 6. 检查端口监听：
#    netstat -tlnp | grep -E "8888|8881|8882|10000|10001|10002|10090"
#
# 7. 检查服务间调用：
#    # User API 调用 User RPC
#    # 查看日志确认调用成功

# ============================================================================
# 【注意事项】
# ============================================================================
# 1. 执行顺序：
#    - 脚本按照数组顺序依次执行
#    - 不是并行执行，而是串行执行
#    - 每个脚本执行完成后，才会执行下一个
#
# 2. 错误处理：
#    - 脚本未使用 set -e
#    - 即使某个服务部署失败，也会继续部署其他服务
#    - 建议在部署完成后检查所有容器状态
#
# 3. 执行时间：
#    - 每个服务需要停止、删除、拉取镜像、启动
#    - 整个过程可能需要几分钟
#    - 取决于网络速度和镜像大小
#
# 4. 依赖服务：
#    - 确保 MySQL、Redis、etcd 等依赖服务已启动
#    - 否则服务启动后会连接失败
#
# 5. 端口冲突：
#    - 确保所有端口未被占用
#    - 端口列表：8888, 8881, 8882, 10000, 10001, 10002, 10090
#
# 6. 镜像权限：
#    - 确保已登录阿里云镜像仓库
#    - 否则无法拉取镜像
#
# 7. 脚本路径：
#    - 必须在 deploy/script 目录下执行
#    - 否则找不到其他脚本文件
#
# 8. POD_IP 配置：
#    - RPC 服务需要 POD_IP 环境变量
#    - 确保各个脚本中的 POD_IP 配置正确

# ============================================================================
# 【故障排查】
# ============================================================================
# 1. 某个服务未启动：
#    - 查看该服务的日志：docker logs <container_name>
#    - 检查端口是否被占用
#    - 检查镜像是否拉取成功
#    - 手动执行该服务的部署脚本
#
# 2. 服务启动但无法访问：
#    - 检查端口映射是否正确：docker port <container_name>
#    - 检查防火墙规则
#    - 检查服务是否真正启动（查看日志）
#
# 3. RPC 服务未注册到 etcd：
#    - 检查 etcd 是否启动
#    - 检查 POD_IP 是否正确
#    - 查看服务日志中的错误信息
#
# 4. API 服务无法调用 RPC 服务：
#    - 检查 RPC 服务是否注册到 etcd
#    - 检查网络连通性
#    - 查看 API 服务日志
#
# 5. 脚本执行失败：
#    - 检查脚本文件是否存在
#    - 检查脚本文件权限
#    - 手动执行脚本查看错误信息

# ============================================================================
# 【优化建议】
# ============================================================================
# 1. 添加错误检查：
#    - 在每个脚本执行后检查返回值
#    - 如果失败，记录错误并继续或中断
#
# 2. 添加日志输出：
#    - 在执行每个脚本前输出提示信息
#    - 例如：echo "正在部署 User RPC 服务..."
#
# 3. 添加等待时间：
#    - 在服务启动后等待几秒
#    - 确保服务完全启动后再部署下一个
#
# 4. 添加健康检查：
#    - 在部署完成后检查服务健康状态
#    - 例如：curl http://localhost:8888/health
#
# 5. 并行部署：
#    - RPC 服务之间可以并行部署
#    - 使用 & 后台执行，提高部署速度
#    - 但要注意资源限制
#
# 6. 回滚机制：
#    - 如果部署失败，自动回滚到上一个版本
#    - 保存旧镜像的标签
#
# 7. 通知机制：
#    - 部署完成后发送通知（邮件、钉钉、企业微信）
#    - 部署失败时发送告警

# ============================================================================
# 【服务依赖关系】
# ============================================================================
# 1. User API → User RPC → MySQL + Redis
# 2. Social API → Social RPC → MySQL + Redis
# 3. IM API → IM RPC → MySQL + Redis
# 4. IM API → User RPC（查询用户信息）
# 5. IM API → Social RPC（检查好友关系）
# 6. IM WS → IM RPC（消息处理）
# 7. Task MQ → 消息队列（Kafka/RabbitMQ/Redis）
# 8. 所有 RPC 服务 → etcd（服务注册）

# ============================================================================
# 【端口分配总结】
# ============================================================================
# API 服务（HTTP）：
# - User API: 8888
# - Social API: 8881
# - IM API: 8882
#
# RPC 服务（gRPC）：
# - User RPC: 10000
# - Social RPC: 10001
# - IM RPC: 10002
#
# WebSocket 服务：
# - IM WS: 10090
#
# Task 服务：
# - Task MQ: 无对外端口

# ============================================================================
# 【执行流程总结】
# ============================================================================
# 1. 遍历服务脚本数组
# 2. 为每个脚本添加执行权限
# 3. 依次执行每个脚本（停止、删除、拉取、启动）
# 4. 显示所有容器状态
# 5. 显示 etcd 中的服务注册信息
# 6. 部署完成

# ============================================================================
# 【使用示例】
# ============================================================================
# 1. 首次部署：
#    cd /path/to/easy-chat/deploy/script
#    bash release-test.sh
#
# 2. 更新部署：
#    cd /path/to/easy-chat/deploy/script
#    bash release-test.sh
#
# 3. 查看部署结果：
#    docker ps
#    docker logs <container_name>
#
# 4. 测试服务：
#    curl http://localhost:8888/health
#    curl http://localhost:8881/health
#    curl http://localhost:8882/health
